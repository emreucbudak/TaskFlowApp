<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="TaskFlowApp.MainPage"
             Title=""
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <ScrollView VerticalOptions="Center">
        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Padding="16,24"
                             Spacing="0"
                             WidthRequest="480">

            <!-- ══ Main Card Container ══ -->
            <Border BackgroundColor="#FFFFFF"
                    Stroke="#E0E7FF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    HorizontalOptions="Fill">
                <Border.Shadow>
                    <Shadow Brush="#204F46E5" Offset="0,12" Radius="40" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!-- ── Header / Logo Section ── -->
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="4"
                                         Padding="32,28,32,20">

                        <!-- Logo Icon -->
                        <Image Source="taskflow_logo.png"
                               WidthRequest="64"
                               HeightRequest="64"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               Margin="0,0,0,16" />


                    </VerticalStackLayout>

                    <!-- ── Form Section ── -->
                    <VerticalStackLayout Spacing="20"
                                         Padding="32,0,32,24">

                        <!-- Email Field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="E-posta"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#334155"
                                   Margin="4,0,0,0" />
                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1.5"
                                    HorizontalOptions="Fill"
                                    HeightRequest="50"
                                    Padding="14,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#08000000" Offset="0,2" Radius="4" />
                                </Border.Shadow>
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Image Source="{mi:MaterialOutlined Icon=Mail, IconColor=#94A3B8}"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           VerticalOptions="Center" />
                                    <Entry Placeholder="isim@sirket.com"
                                           PlaceholderColor="#94A3B8"
                                           TextColor="#0F172A"
                                           FontSize="14"
                                           BackgroundColor="Transparent"
                                           Keyboard="Email"
                                           Text="{Binding Email}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="FillAndExpand"
                                           HandlerChanged="OnEntryHandlerChanged"
                                           x:Name="EmailEntry" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password Field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="&#350;ifre"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#334155"
                                   Margin="4,0,0,0" />
                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1.5"
                                    HorizontalOptions="Fill"
                                    HeightRequest="50"
                                    Padding="14,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#08000000" Offset="0,2" Radius="4" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                                    <Image Source="{mi:MaterialOutlined Icon=Lock, IconColor=#94A3B8}"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           VerticalOptions="Center" />
                                    <Entry Grid.Column="1"
                                           Placeholder="&#350;ifrenizi girin"
                                           PlaceholderColor="#94A3B8"
                                           TextColor="#0F172A"
                                           FontSize="14"
                                           BackgroundColor="Transparent"
                                           IsPassword="{Binding IsPasswordHidden}"
                                           Text="{Binding Password}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="FillAndExpand"
                                           Margin="10,0,0,0"
                                           HandlerChanged="OnEntryHandlerChanged"
                                           x:Name="PasswordEntry" />
                                    <Border Grid.Column="2"
                                            BackgroundColor="Transparent"
                                            Stroke="Transparent"
                                            StrokeThickness="0"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            VerticalOptions="Center">
                                        <Image Source="{mi:MaterialOutlined Icon=Visibility}"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               Opacity="0.5"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </Border>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Sign In Button -->
                        <Button Text="Giri&#351; Yap"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="White"
                                HeightRequest="50"
                                CornerRadius="12"
                                HorizontalOptions="Fill"
                                BackgroundColor="#4F46E5"
                                Command="{Binding LoginCommand}">
                            <Button.Shadow>
                                <Shadow Brush="#504F46E5" Offset="0,4" Radius="12" />
                            </Button.Shadow>
                        </Button>

                        <!-- Error Message -->
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#DC2626"
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />

                    </VerticalStackLayout>


                </VerticalStackLayout>
            </Border>

            <!-- Bottom Copyright -->
            <Label Text="&#169; 2026 TASKFLOW KURUMSAL &#199;&#214;Z&#220;MLER"
                   FontSize="11"
                   TextColor="#94A3B8"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   Margin="0,24,0,0"
                   CharacterSpacing="2" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
