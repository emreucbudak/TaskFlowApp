<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaskFlowApp.Controls.ProfileDrawer"
             x:Name="Root"
             IsVisible="False"
             InputTransparent="True">
    <Grid BackgroundColor="Transparent">
        <BoxView x:Name="Backdrop"
                 BackgroundColor="#000000"
                 Opacity="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseProfileMenuCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Grid HorizontalOptions="End"
              WidthRequest="320">
            <Border x:Name="DrawerPanel"
                    BackgroundColor="#FFFFFF"
                    Stroke="#E0E7FF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12,0,12,0"
                    Padding="20,24,20,20"
                    Margin="0"
                    TranslationX="340">
                <Border.Shadow>
                    <Shadow Brush="#404F46E5" Offset="-4,0" Radius="16" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,*,Auto"
                      RowSpacing="16">

                    <!-- User Info Card -->
                    <Border BackgroundColor="#EEF2FF"
                            Stroke="#C7D2FE"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="16">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border BackgroundColor="#4F46E5"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    WidthRequest="52"
                                    HeightRequest="52">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Label Text="{Binding CurrentUserInitials}"
                                       TextColor="White"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding CurrentUserDisplayName}"
                                       TextColor="#1E1B4B"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Text="{Binding CurrentUserRoleText}"
                                       TextColor="#4F46E5"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Text="{Binding CurrentUserSupportText}"
                                       TextColor="#64748B"
                                       FontSize="11"
                                       IsVisible="{Binding HasCurrentUserSupportText}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Navigation Items -->
                    <ScrollView Grid.Row="1" VerticalOptions="Center">
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">

                            <!-- Profile -->
                            <Grid x:Name="ProfileMenuCard"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  Padding="14,12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateProfileCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="Profilim"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="&#x203A;"
                                       TextColor="#94A3B8"
                                       FontSize="28"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Group -->
                            <Grid x:Name="GroupMenuCard"
                                  IsVisible="{Binding ShowGroupNavigation}"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  Padding="14,12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateGroupDetailsCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="Grubum"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="&#x203A;"
                                       TextColor="#94A3B8"
                                       FontSize="28"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Create Report (Worker only) -->
                            <Grid x:Name="CreateReportMenuCard"
                                  IsVisible="{Binding IsWorkerUser}"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  Padding="14,12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateCreateReportCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="Rapor Olu&#351;tur"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="&#x203A;"
                                       TextColor="#94A3B8"
                                       FontSize="28"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Reports -->
                            <Grid x:Name="ReportsMenuCard"
                                  IsVisible="{Binding ShowReportsNavigation}"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  Padding="14,12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateReportsCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="Raporlar"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="&#x203A;"
                                       TextColor="#94A3B8"
                                       FontSize="28"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Tasks -->
                            <Grid x:Name="TasksMenuCard"
                                  IsVisible="{Binding ShowTasksNavigation}"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  Padding="14,12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateTasksCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="G&#246;revler"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="&#x203A;"
                                       TextColor="#94A3B8"
                                       FontSize="28"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Leader Management -->
                            <Grid x:Name="LeaderMenuCard"
                                  IsVisible="{Binding ShowLeaderManagementNavigation}"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  Padding="14,12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateLeaderTasksCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="Y&#246;netim"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="&#x203A;"
                                       TextColor="#94A3B8"
                                       FontSize="28"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Logout -->
                    <Border Grid.Row="2"
                            BackgroundColor="#DC2626"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Label Text="&#199;&#305;k&#305;&#351; Yap"
                                   TextColor="White"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="&#x203A;"
                                   TextColor="White"
                                   FontSize="28"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>
