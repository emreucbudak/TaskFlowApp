<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="TaskFlowApp.Controls.AppBottomNav"
             x:Name="Root">
    <Grid ColumnDefinitions="*,*,*,*"
          BackgroundColor="#0F1E2D"
          Padding="16,8,16,22">
        <VerticalStackLayout Grid.Column="0"
                             HorizontalOptions="Center"
                             Spacing="4">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateHomeCommand}" />
            </VerticalStackLayout.GestureRecognizers>
            <Border x:Name="HomeBorder"
                    BackgroundColor="#162838"
                    Stroke="#24384B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    WidthRequest="42"
                    HeightRequest="32"
                    HorizontalOptions="Center">
                <Image Source="{mi:MaterialOutlined Icon=Home}"
                       WidthRequest="18"
                       HeightRequest="18"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            <BoxView x:Name="HomeDot"
                     Color="#2196F3"
                     WidthRequest="4"
                     HeightRequest="3"
                     CornerRadius="1.5"
                     HorizontalOptions="Center"
                     IsVisible="False" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             Spacing="4"
                             IsVisible="{Binding IsWorkerUser}">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateNotificationsCommand}" />
            </VerticalStackLayout.GestureRecognizers>
            <Border x:Name="NotificationWorkerBorder"
                    BackgroundColor="#162838"
                    Stroke="#24384B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    WidthRequest="42"
                    HeightRequest="32"
                    HorizontalOptions="Center">
                <Image Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                       WidthRequest="18"
                       HeightRequest="18"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            <BoxView x:Name="NotificationWorkerDot"
                     Color="#2196F3"
                     WidthRequest="4"
                     HeightRequest="3"
                     CornerRadius="1.5"
                     HorizontalOptions="Center"
                     IsVisible="False" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             Spacing="4"
                             IsVisible="{Binding IsCompanyUser}">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateNotificationsCommand}" />
            </VerticalStackLayout.GestureRecognizers>
            <Border x:Name="NotificationCompanyBorder"
                    BackgroundColor="#162838"
                    Stroke="#24384B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    WidthRequest="42"
                    HeightRequest="32"
                    HorizontalOptions="Center">
                <Image Source="{mi:MaterialOutlined Icon=Subscriptions}"
                       WidthRequest="18"
                       HeightRequest="18"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            <BoxView x:Name="NotificationCompanyDot"
                     Color="#2196F3"
                     WidthRequest="4"
                     HeightRequest="3"
                     CornerRadius="1.5"
                     HorizontalOptions="Center"
                     IsVisible="False" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="2"
                             HorizontalOptions="Center"
                             Spacing="4"
                             IsVisible="{Binding IsWorkerUser}">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateMessagesCommand}" />
            </VerticalStackLayout.GestureRecognizers>
            <Border x:Name="SecondaryWorkerBorder"
                    BackgroundColor="#162838"
                    Stroke="#24384B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    WidthRequest="42"
                    HeightRequest="32"
                    HorizontalOptions="Center">
                <Image Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                       WidthRequest="18"
                       HeightRequest="18"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            <BoxView x:Name="SecondaryWorkerDot"
                     Color="#2196F3"
                     WidthRequest="4"
                     HeightRequest="3"
                     CornerRadius="1.5"
                     HorizontalOptions="Center"
                     IsVisible="False" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="2"
                             HorizontalOptions="Center"
                             Spacing="4"
                             IsVisible="{Binding IsCompanyUser}">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateMessagesCommand}" />
            </VerticalStackLayout.GestureRecognizers>
            <Border x:Name="SecondaryCompanyBorder"
                    BackgroundColor="#162838"
                    Stroke="#24384B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    WidthRequest="42"
                    HeightRequest="32"
                    HorizontalOptions="Center">
                <Image Source="{mi:MaterialOutlined Icon=ManageAccounts}"
                       WidthRequest="18"
                       HeightRequest="18"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            <BoxView x:Name="SecondaryCompanyDot"
                     Color="#2196F3"
                     WidthRequest="4"
                     HeightRequest="3"
                     CornerRadius="1.5"
                     HorizontalOptions="Center"
                     IsVisible="False" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="3"
                             HorizontalOptions="Center"
                             Spacing="4">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleProfileMenuCommand}" />
            </VerticalStackLayout.GestureRecognizers>
            <Border x:Name="ProfileBorder"
                    BackgroundColor="#162838"
                    Stroke="#24384B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    WidthRequest="42"
                    HeightRequest="32"
                    HorizontalOptions="Center">
                <Grid WidthRequest="18"
                      HeightRequest="18"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Ellipse WidthRequest="7"
                             HeightRequest="7"
                             Fill="#dbeafe"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Margin="0,1,0,0" />
                    <Ellipse WidthRequest="13"
                             HeightRequest="9"
                             Fill="#dbeafe"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,1" />
                </Grid>
            </Border>
            <BoxView x:Name="ProfileDot"
                     Color="#2196F3"
                     WidthRequest="4"
                     HeightRequest="3"
                     CornerRadius="1.5"
                     HorizontalOptions="Center"
                     IsVisible="False" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
