<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.TasksPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16,20,20" Spacing="18">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12" />

                <!-- Section Header: Bireysel Gorevler -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" CornerRadius="2" VerticalOptions="Fill" />
                    <Label Grid.Column="1"
                           Text="Bireysel G&#246;revler"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1E1B4B"
                           VerticalOptions="Center" />
                    <Button Grid.Column="2"
                            Text="T&#252;m&#252;n&#252; G&#246;r"
                            Command="{Binding ShowAllIndividualTasksCommand}"
                            BackgroundColor="#4F46E5"
                            TextColor="White"
                            CornerRadius="4"
                            HeightRequest="28"
                            Padding="12,4"
                            FontSize="12" />
                </Grid>

                <CollectionView ItemsSource="{Binding IndividualTasks}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="Bireysel g&#246;rev bulunamad&#305;."
                               FontSize="12"
                               TextColor="#94A3B8"
                               HorizontalTextAlignment="Center"
                               Margin="0,8,0,0" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <Grid ColumnDefinitions="4,*">
                                    <BoxView Grid.Column="0" Color="#4F46E5" CornerRadius="4,0,0,4" />
                                    <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="8">
                                        <Label Text="{Binding TaskName}"
                                               TextColor="#1E1B4B"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Description}"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <FlexLayout Wrap="Wrap"
                                                    Direction="Row"
                                                    AlignItems="Center"
                                                    JustifyContent="Start">
                                            <!-- Deadline pill -->
                                            <Border BackgroundColor="#EEF2FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=AccessTime}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DeadlineTime, StringFormat='Teslim: {0:dd.MM.yyyy}'}"
                                                           TextColor="#4F46E5"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Status pill -->
                                            <Border BackgroundColor="#DFF6DD"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Info}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding StatusName, StringFormat='Durum: {0}'}"
                                                           TextColor="#107C10"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Category pill -->
                                            <Border BackgroundColor="#F0F0FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Category}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding CategoryName, StringFormat='Kategori: {0}'}"
                                                           TextColor="#5B5FC7"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Priority pill -->
                                            <Border BackgroundColor="#FDE7E9"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Flag}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding TaskPriorityName, StringFormat='&#214;ncelik: {0}'}"
                                                           TextColor="#A4262C"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Section Header: Grup Gorevleri -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,4,0,0">
                    <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" CornerRadius="2" VerticalOptions="Fill" />
                    <Label Grid.Column="1"
                           Text="Grup G&#246;revleri"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1E1B4B"
                           VerticalOptions="Center" />
                    <Button Grid.Column="2"
                            Text="T&#252;m&#252;n&#252; G&#246;r"
                            Command="{Binding ShowAllGroupTasksCommand}"
                            IsEnabled="{Binding CanShowAllGroupTasks}"
                            BackgroundColor="#4F46E5"
                            TextColor="White"
                            CornerRadius="4"
                            HeightRequest="28"
                            Padding="12,4"
                            FontSize="12" />
                </Grid>

                <CollectionView ItemsSource="{Binding GroupTasks}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="Grup g&#246;revi bulunamad&#305;."
                               FontSize="12"
                               TextColor="#94A3B8"
                               HorizontalTextAlignment="Center"
                               Margin="0,8,0,0" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <Grid ColumnDefinitions="4,*">
                                    <BoxView Grid.Column="0" Color="#4F46E5" CornerRadius="4,0,0,4" />
                                    <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="8">
                                        <Label Text="{Binding TaskName}"
                                               TextColor="#1E1B4B"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Description}"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <FlexLayout Wrap="Wrap"
                                                    Direction="Row"
                                                    AlignItems="Center"
                                                    JustifyContent="Start">
                                            <!-- Deadline pill -->
                                            <Border BackgroundColor="#EEF2FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=AccessTime}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DeadlineTime, StringFormat='Teslim: {0:dd.MM.yyyy}'}"
                                                           TextColor="#4F46E5"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Status pill -->
                                            <Border BackgroundColor="#DFF6DD"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Info}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding StatusName, StringFormat='Durum: {0}'}"
                                                           TextColor="#107C10"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Category pill -->
                                            <Border BackgroundColor="#F0F0FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Category}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding CategoryName, StringFormat='Kategori: {0}'}"
                                                           TextColor="#5B5FC7"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Priority pill -->
                                            <Border BackgroundColor="#FDE7E9"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Flag}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding TaskPriorityName, StringFormat='&#214;ncelik: {0}'}"
                                                           TextColor="#A4262C"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Hidden FlexLayout Nav -->
        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="6"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem="Tasks"
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
