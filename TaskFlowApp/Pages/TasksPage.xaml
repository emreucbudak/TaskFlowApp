<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="TaskFlowApp.Pages.TasksPage"
             BackgroundColor="#0D1B2A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid Grid.Row="0"
              Padding="20,16,20,10"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#0D1B2A">
            <Image Grid.Column="0"
                   Source="https://www.logoai.com/uploads/icon/2021/08/06/732ca933-7df8-43e8-b085-69466243c919.png"
                   WidthRequest="32"
                   HeightRequest="32"
                   Aspect="AspectFit"
                   VerticalOptions="Center" />

            <Grid Grid.Column="2"
                  WidthRequest="44"
                  HeightRequest="44"
                  HorizontalOptions="End"
                  VerticalOptions="Center">
                <Ellipse WidthRequest="44"
                         HeightRequest="44"
                         Stroke="#3A5068"
                         StrokeThickness="1.5"
                         Fill="#1A3A5C"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
                <Grid WidthRequest="44"
                      HeightRequest="44"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Ellipse WidthRequest="16"
                             HeightRequest="16"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Margin="0,10,0,0" />
                    <Ellipse WidthRequest="28"
                             HeightRequest="20"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,2" />
                </Grid>
                <Ellipse WidthRequest="12"
                         HeightRequest="12"
                         Fill="#4CAF50"
                         Stroke="#0D1B2A"
                         StrokeThickness="2"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="0,0,1,1" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,14,20,20" Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#2196F3" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#f87171"
                       FontSize="12" />

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="Bireysel G&#246;revler"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="T&#252;m&#252;n&#252; G&#246;r"
                            Command="{Binding ShowAllIndividualTasksCommand}"
                            IsEnabled="{Binding CanShowAllIndividualTasks}"
                            BackgroundColor="#1A3A5C"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="28"
                            Padding="12,4"
                            FontSize="12" />
                </Grid>
                    <CollectionView ItemsSource="{Binding IndividualTasks}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Bireysel g&#246;rev bulunamad&#305;."
                                   FontSize="12"
                                   TextColor="#94a3b8"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,8,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#0F2338"
                                        Stroke="#2E4A67"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Margin="0,0,0,6"
                                        Padding="12">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding TaskName}"
                                               TextColor="White"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Description}"
                                               TextColor="#94a3b8"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <FlexLayout Wrap="Wrap"
                                                    Direction="Row"
                                                    AlignItems="Center"
                                                    JustifyContent="Start">
                                            <Border BackgroundColor="#0F2D46"
                                                    Stroke="#3b82f6"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=AccessTime}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DeadlineTime, StringFormat='Teslim: {0:dd.MM.yyyy}'}"
                                                           TextColor="#bfdbfe"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <Border BackgroundColor="#102D22"
                                                    Stroke="#22c55e"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Info}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding StatusName, StringFormat='Durum: {0}'}"
                                                           TextColor="#bbf7d0"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <Border BackgroundColor="#30230E"
                                                    Stroke="#f59e0b"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Category}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding CategoryName, StringFormat='Kategori: {0}'}"
                                                           TextColor="#fde68a"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <Border BackgroundColor="#30142A"
                                                    Stroke="#ec4899"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Flag}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding TaskPriorityName, StringFormat='&#214;ncelik: {0}'}"
                                                           TextColor="#fbcfe8"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12"
                      Margin="0,4,0,0">
                    <Label Grid.Column="0"
                           Text="Grup G&#246;revleri"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="T&#252;m&#252;n&#252; G&#246;r"
                            Command="{Binding ShowAllGroupTasksCommand}"
                            IsEnabled="{Binding CanShowAllGroupTasks}"
                            BackgroundColor="#1A3A5C"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="28"
                            Padding="12,4"
                            FontSize="12" />
                </Grid>
                    <CollectionView ItemsSource="{Binding GroupTasks}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Grup g&#246;revi bulunamad&#305;."
                                   FontSize="12"
                                   TextColor="#94a3b8"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,8,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#0F2338"
                                        Stroke="#2E4A67"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Margin="0,0,0,6"
                                        Padding="12">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding TaskName}"
                                               TextColor="White"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Description}"
                                               TextColor="#94a3b8"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <FlexLayout Wrap="Wrap"
                                                    Direction="Row"
                                                    AlignItems="Center"
                                                    JustifyContent="Start">
                                            <Border BackgroundColor="#0F2D46"
                                                    Stroke="#3b82f6"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=AccessTime}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DeadlineTime, StringFormat='Teslim: {0:dd.MM.yyyy}'}"
                                                           TextColor="#bfdbfe"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <Border BackgroundColor="#102D22"
                                                    Stroke="#22c55e"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Info}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding StatusName, StringFormat='Durum: {0}'}"
                                                           TextColor="#bbf7d0"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <Border BackgroundColor="#30230E"
                                                    Stroke="#f59e0b"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Category}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding CategoryName, StringFormat='Kategori: {0}'}"
                                                           TextColor="#fde68a"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <Border BackgroundColor="#30142A"
                                                    Stroke="#ec4899"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Flag}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding TaskPriorityName, StringFormat='&#214;ncelik: {0}'}"
                                                           TextColor="#fbcfe8"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="3"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <FlexLayout Grid.Row="4"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#0F1E2D"
                    Padding="30,10,30,24">
            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#2196F3"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>
    </Grid>
</ContentPage>

