<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.NotificationsPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1"
              Padding="20,16,20,20"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="10">
            <ActivityIndicator Grid.Row="0"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#4F46E5" />

            <Label Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   TextColor="#A4262C"
                   FontSize="12" />

            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Notifications}"
                            SelectionMode="None"
                            RemainingItemsThreshold="2"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,30,0,0">
                        <Label Text="Bildirim bulunmuyor."
                               HorizontalOptions="Center"
                               TextColor="#94A3B8"
                               FontSize="13" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                            <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsRead}"
                                             Value="False">
                                    <Setter Property="BackgroundColor" Value="#EBF3FC" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="4,*">
                                <!-- Blue left accent for unread -->
                                <BoxView Grid.Column="0" Color="Transparent" CornerRadius="4,0,0,4">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView"
                                                     Binding="{Binding IsRead}"
                                                     Value="False">
                                            <Setter Property="Color" Value="#4F46E5" />
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>

                                <VerticalStackLayout Grid.Column="1" Padding="14" Spacing="6">
                                    <Label Text="{Binding Title}"
                                           TextColor="#64748B"
                                           FontSize="14"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsRead}"
                                                         Value="False">
                                                <Setter Property="TextColor" Value="#1E1B4B" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Text="{Binding Description}"
                                           TextColor="#64748B"
                                           FontSize="12"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsRead}"
                                                         Value="False">
                                                <Setter Property="TextColor" Value="#1E1B4B" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Text="{Binding SendTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator Grid.Row="3"
                               Margin="0,4,0,0"
                               IsRunning="{Binding IsLoadingMore}"
                               IsVisible="{Binding IsLoadingMore}"
                               Color="#4F46E5" />
        </Grid>

        <!-- Hidden FlexLayout Nav -->
        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2" IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="6" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="Notifications" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem=""
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
