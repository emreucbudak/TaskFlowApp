<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.LeaderIndividualTaskPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,14,20,20"
                                 Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12"
                       LineBreakMode="WordWrap" />

                <!-- No Access Card -->
                <Border BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="16"
                        IsVisible="{Binding HasNoManagementAccess}">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Erişim Yok"
                               TextColor="#1E1B4B"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="{Binding AccessMessage}"
                               TextColor="#64748B"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Management Access Content -->
                <VerticalStackLayout Spacing="16"
                                     IsVisible="{Binding HasManagementAccess}">

                    <!-- Task Creation Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <!-- Section Header with blue bar -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" HeightRequest="22" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Bireysel Görev Atama"
                                       TextColor="#1E1B4B"
                                       FontSize="17"
                                       FontAttributes="Bold" />
                            </Grid>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="6,0">
                                <Picker ItemsSource="{Binding EligibleUsers}"
                                        SelectedItem="{Binding SelectedAssignedUser}"
                                        ItemDisplayBinding="{Binding Name}"
                                        Title="Kullanıcı seç"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="6,0">
                                <Picker ItemsSource="{Binding PriorityOptions}"
                                        SelectedItem="{Binding SelectedPriority}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        Title="Öncelik seç"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <Entry Text="{Binding TaskTitle}"
                                       Placeholder="Görev başlığı"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1E1B4B"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12">
                                <Editor Text="{Binding Description}"
                                        Placeholder="Görev açıklaması"
                                        PlaceholderColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="120"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Teslim Tarihi"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                    <DatePicker Date="{Binding DeadlineDate}"
                                                MinimumDate="{Binding MinimumDeadlineDate}"
                                                TextColor="#1E1B4B"
                                                BackgroundColor="Transparent"
                                                HandlerChanged="OnInputHandlerChanged" />
                                </VerticalStackLayout>
                            </Border>

                            <Button Text="Görev Oluştur"
                                    Command="{Binding CreateTaskCommand}"
                                    BackgroundColor="#4F46E5"
                                    TextColor="White"
                                    CornerRadius="4"
                                    HeightRequest="46" />

                            <Label Text="{Binding CreateStatus}"
                                   TextColor="#107C10"
                                   FontSize="11"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Divider -->
                    <BoxView Color="#E0E0E0"
                             HeightRequest="1"
                             HorizontalOptions="Fill" />

                    <!-- Group Creation Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18"
                            IsVisible="{Binding CanCreateGroups}">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <!-- Section Header with blue bar -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" HeightRequest="22" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="Grup Oluşturma"
                                           TextColor="#1E1B4B"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding GroupCreateHelperText}"
                                           TextColor="#94A3B8"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <Picker ItemsSource="{Binding ManagedDepartments}"
                                    SelectedItem="{Binding SelectedManagedDepartment}"
                                    ItemDisplayBinding="{Binding DepartmentName}"
                                    Title="Departman seç"
                                    TitleColor="#94A3B8"
                                    TextColor="#1E1B4B"
                                    BackgroundColor="Transparent"
                                    IsVisible="{Binding ShowGroupDepartmentPicker}"
                                    HandlerChanged="OnInputHandlerChanged" />

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <Entry Text="{Binding GroupNameInput}"
                                       Placeholder="Grup adı"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1E1B4B"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <!-- User Selection Dropdown -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0"
                                        BackgroundColor="#FFFFFF"
                                        Stroke="#C7D2FE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="6,0">
                                    <Picker ItemsSource="{Binding AvailableGroupUserOptions}"
                                            SelectedItem="{Binding SelectedGroupUserToAdd}"
                                            ItemDisplayBinding="{Binding Name}"
                                            Title="&#220;ye se&#231;"
                                            TitleColor="#94A3B8"
                                            TextColor="#1E1B4B"
                                            BackgroundColor="Transparent"
                                            HandlerChanged="OnInputHandlerChanged" />
                                </Border>
                                <Button Grid.Column="1"
                                        Text="Ekle"
                                        Command="{Binding AddGroupMemberCommand}"
                                        BackgroundColor="#4F46E5"
                                        TextColor="White"
                                        CornerRadius="4"
                                        HeightRequest="40"
                                        WidthRequest="70"
                                        FontSize="13" />
                            </Grid>

                            <!-- Selected Members List -->
                            <CollectionView ItemsSource="{Binding SelectedGroupMembers}"
                                            SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                                       ItemSpacing="6" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.EmptyView>
                                    <Label Text="Hen&#252;z &#252;ye eklenmedi."
                                           FontSize="11"
                                           TextColor="#94A3B8"
                                           HorizontalTextAlignment="Center"
                                           Margin="0,8,0,0" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:Object">
                                        <Border BackgroundColor="#EEF2FF"
                                                Stroke="#C7D2FE"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 4"
                                                Padding="10,8">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                                    <Label Text="{Binding Name}"
                                                           TextColor="#1E1B4B"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding DepartmentName}"
                                                           TextColor="#64748B"
                                                           FontSize="11"
                                                           LineBreakMode="TailTruncation" />
                                                </VerticalStackLayout>
                                                <Button Grid.Column="1"
                                                        Text="Kaldir"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveGroupMemberCommand}"
                                                        CommandParameter="{Binding}"
                                                        BackgroundColor="#FEE2E2"
                                                        TextColor="#A4262C"
                                                        CornerRadius="4"
                                                        HeightRequest="30"
                                                        FontSize="11"
                                                        Padding="8,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- Group Task Toggle -->
                            <Border BackgroundColor="#EEF2FF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14,10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="Grup Gorevi Ekle"
                                           TextColor="#1E1B4B"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center" />
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding IsGroupTaskEnabled}"
                                            OnColor="#4F46E5"
                                            ThumbColor="#FFFFFF" />
                                </Grid>
                            </Border>

                            <!-- Group Task Form -->
                            <VerticalStackLayout Spacing="12"
                                                 IsVisible="{Binding IsGroupTaskEnabled}">

                                <Border BackgroundColor="#EEF2FF"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="12">
                                    <Label Text="Ana g&#246;rev bilgilerini doldurun. Her &#252;ye i&#231;in alt g&#246;revler otomatik olu&#351;turulur."
                                           TextColor="#64748B"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </Border>

                                <Picker ItemsSource="{Binding PriorityOptions}"
                                        SelectedItem="{Binding SelectedGroupTaskPriority}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        Title="Gorev onceligi sec"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        HandlerChanged="OnInputHandlerChanged" />

                                <Border BackgroundColor="#FFFFFF"
                                        Stroke="#C7D2FE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="12,8">
                                    <Entry Text="{Binding GroupTaskTitle}"
                                           Placeholder="Grup g&#246;rev ba&#351;l&#305;&#287;&#305;"
                                           PlaceholderColor="#94A3B8"
                                           TextColor="#1E1B4B"
                                           BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing"
                                           HandlerChanged="OnInputHandlerChanged" />
                                </Border>

                                <Border BackgroundColor="#FFFFFF"
                                        Stroke="#C7D2FE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="12">
                                    <Editor Text="{Binding GroupTaskDescription}"
                                            Placeholder="Grup g&#246;rev a&#231;&#305;klamas&#305;"
                                            PlaceholderColor="#94A3B8"
                                            TextColor="#1E1B4B"
                                            BackgroundColor="Transparent"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            HandlerChanged="OnInputHandlerChanged" />
                                </Border>

                                <Border BackgroundColor="#FFFFFF"
                                        Stroke="#C7D2FE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="12,8">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Gorev Teslim Tarihi"
                                               TextColor="#94A3B8"
                                               FontSize="11" />
                                        <DatePicker Date="{Binding GroupTaskDeadlineDate}"
                                                    MinimumDate="{Binding MinimumDeadlineDate}"
                                                    TextColor="#1E1B4B"
                                                    BackgroundColor="Transparent"
                                                    HandlerChanged="OnInputHandlerChanged" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Sub Tasks per Member -->
                                <Label Text="&#220;ye Alt G&#246;revleri"
                                       TextColor="#1E1B4B"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       Margin="0,6,0,0" />

                                <CollectionView ItemsSource="{Binding GroupMemberSubTasks}"
                                                SelectionMode="None">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Vertical"
                                                           ItemSpacing="10" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.EmptyView>
                                        <Label Text="&#220;ye se&#231;ildikten sonra alt g&#246;revler burada g&#246;r&#252;necektir."
                                               FontSize="11"
                                               TextColor="#94A3B8"
                                               HorizontalTextAlignment="Center"
                                               Margin="0,8,0,0" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#F8FAFC"
                                                    Stroke="#E2E8F0"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 4"
                                                    Padding="12">
                                                <VerticalStackLayout Spacing="8">
                                                    <Label Text="{Binding MemberName}"
                                                           TextColor="#4F46E5"
                                                           FontSize="13"
                                                           FontAttributes="Bold" />
                                                    <Entry Text="{Binding SubTaskTitle}"
                                                           Placeholder="Alt g&#246;rev ba&#351;l&#305;&#287;&#305;"
                                                           PlaceholderColor="#94A3B8"
                                                           TextColor="#1E1B4B"
                                                           BackgroundColor="#FFFFFF"
                                                           HandlerChanged="OnInputHandlerChanged" />
                                                    <Editor Text="{Binding SubTaskDescription}"
                                                            Placeholder="Alt g&#246;rev a&#231;&#305;klamas&#305;"
                                                            PlaceholderColor="#94A3B8"
                                                            TextColor="#1E1B4B"
                                                            BackgroundColor="#FFFFFF"
                                                            AutoSize="TextChanges"
                                                            MinimumHeightRequest="60"
                                                            HandlerChanged="OnInputHandlerChanged" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                            <Button Text="{Binding GroupCreateButtonText}"
                                    Command="{Binding CreateGroupCommand}"
                                    BackgroundColor="#4F46E5"
                                    TextColor="White"
                                    CornerRadius="4"
                                    HeightRequest="46" />

                            <Label Text="{Binding GroupCreationStatus}"
                                   TextColor="#107C10"
                                   FontSize="11"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Divider -->
                    <BoxView Color="#E0E0E0"
                             HeightRequest="1"
                             HorizontalOptions="Fill" />

                    <!-- Group Deletion Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <!-- Section Header with blue bar -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <BoxView Grid.Column="0" Color="#A4262C" WidthRequest="4" HeightRequest="22" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="Grup Silme"
                                           TextColor="#1E1B4B"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding GroupDeleteHelperText}"
                                           TextColor="#94A3B8"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <Picker ItemsSource="{Binding AvailableGroups}"
                                    SelectedItem="{Binding SelectedGroupToDelete}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    Title="Grup seç"
                                    TitleColor="#94A3B8"
                                    TextColor="#1E1B4B"
                                    BackgroundColor="Transparent"
                                    IsEnabled="{Binding CanDeleteGroups}"
                                    HandlerChanged="OnInputHandlerChanged" />

                            <Border BackgroundColor="#EEF2FF"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12"
                                    IsVisible="{Binding HasSelectedGroupToDelete}">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Departmanlar"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                    <Label Text="{Binding SelectedDeleteGroupDepartmentsText}"
                                           TextColor="#1E1B4B"
                                           FontSize="13"
                                           LineBreakMode="WordWrap" />
                                    <Label Text="&#220;yeler"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                    <Label Text="{Binding SelectedDeleteGroupMembersText}"
                                           TextColor="#1E1B4B"
                                           FontSize="13"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>

                            <Button Text="Grubu Sil"
                                    Command="{Binding DeleteSelectedGroupCommand}"
                                    IsEnabled="{Binding CanUseDeleteGroupForm}"
                                    BackgroundColor="#A4262C"
                                    TextColor="White"
                                    CornerRadius="4"
                                    HeightRequest="46" />

                            <Label Text="{Binding GroupDeletionStatus}"
                                   TextColor="#A4262C"
                                   FontSize="11"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding ShowReportsNavigation}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding ShowManagementNavigation}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="2"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem="Leader"
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>
