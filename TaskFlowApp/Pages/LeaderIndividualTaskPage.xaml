<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.LeaderIndividualTaskPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,14,20,20"
                                 Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12"
                       LineBreakMode="WordWrap" />

                <!-- No Access Card -->
                <Border BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="16"
                        IsVisible="{Binding HasNoManagementAccess}">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Erişim Yok"
                               TextColor="#1E1B4B"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="{Binding AccessMessage}"
                               TextColor="#64748B"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Management Access Content -->
                <VerticalStackLayout Spacing="16"
                                     IsVisible="{Binding HasManagementAccess}">

                    <!-- Page Title -->
                    <Label Text="Görev ve Grup Yönetimi"
                           TextColor="#1E1B4B"
                           FontSize="22"
                           FontAttributes="Bold" />
                    <Label Text="{Binding StatusText}"
                           TextColor="#64748B"
                           FontSize="12"
                           LineBreakMode="WordWrap"
                           Margin="0,-12,0,0" />

                    <!-- Yetki Alani Info Panel -->
                    <Border BackgroundColor="#EEF2FF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Yetki Alanı"
                                   TextColor="#94A3B8"
                                   FontSize="11" />
                            <Label Text="{Binding CurrentDepartmentName}"
                                   TextColor="#1E1B4B"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Task Creation Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <!-- Section Header with blue bar -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" HeightRequest="22" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Bireysel Görev Atama"
                                       TextColor="#1E1B4B"
                                       FontSize="17"
                                       FontAttributes="Bold" />
                            </Grid>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="10,4">
                                <Picker ItemsSource="{Binding EligibleUsers}"
                                        SelectedItem="{Binding SelectedAssignedUser}"
                                        ItemDisplayBinding="{Binding Name}"
                                        Title="Kullanıcı seç"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="10,4">
                                <Picker ItemsSource="{Binding PriorityOptions}"
                                        SelectedItem="{Binding SelectedPriority}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        Title="Öncelik seç"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <Entry Text="{Binding TaskTitle}"
                                       Placeholder="Görev başlığı"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1E1B4B"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12">
                                <Editor Text="{Binding Description}"
                                        Placeholder="Görev açıklaması"
                                        PlaceholderColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="120"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Teslim Tarihi"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                    <DatePicker Date="{Binding DeadlineDate}"
                                                MinimumDate="{Binding MinimumDeadlineDate}"
                                                TextColor="#1E1B4B"
                                                BackgroundColor="Transparent"
                                                HandlerChanged="OnInputHandlerChanged" />
                                </VerticalStackLayout>
                            </Border>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Button Grid.Column="0"
                                        Text="Görev Oluştur"
                                        Command="{Binding CreateTaskCommand}"
                                        BackgroundColor="#4F46E5"
                                        TextColor="White"
                                        CornerRadius="4"
                                        HeightRequest="46" />

                                <ActivityIndicator Grid.Column="1"
                                                   WidthRequest="24"
                                                   HeightRequest="24"
                                                   IsRunning="{Binding IsCreatingTask}"
                                                   IsVisible="{Binding IsCreatingTask}"
                                                   Color="#4F46E5"
                                                   VerticalOptions="Center" />
                            </Grid>

                            <Label Text="{Binding CreateStatus}"
                                   TextColor="#107C10"
                                   FontSize="11"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Divider -->
                    <BoxView Color="#E0E0E0"
                             HeightRequest="1"
                             HorizontalOptions="Fill" />

                    <!-- Group Creation Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18"
                            IsVisible="{Binding CanCreateGroups}">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <!-- Section Header with blue bar -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" HeightRequest="22" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="Grup Oluşturma"
                                           TextColor="#1E1B4B"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding GroupCreateHelperText}"
                                           TextColor="#94A3B8"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="10,4"
                                    IsVisible="{Binding ShowGroupDepartmentPicker}">
                                <Picker ItemsSource="{Binding ManagedDepartments}"
                                        SelectedItem="{Binding SelectedManagedDepartment}"
                                        ItemDisplayBinding="{Binding DepartmentName}"
                                        Title="Departman seç"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <Entry Text="{Binding GroupNameInput}"
                                       Placeholder="Grup adı"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1E1B4B"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <CollectionView ItemsSource="{Binding GroupEligibleUsers}"
                                            SelectionMode="None"
                                            HeightRequest="220">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                                       ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.EmptyView>
                                    <Label Text="Secilebilecek kullanici bulunmuyor."
                                           FontSize="11"
                                           TextColor="#94A3B8"
                                           HorizontalTextAlignment="Center"
                                           Margin="0,12,0,0" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#FFFFFF"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 4"
                                                Padding="10">
                                            <Border.Shadow>
                                                <Shadow Brush="#204F46E5" Offset="0,1" Radius="4" />
                                            </Border.Shadow>
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <VerticalStackLayout Grid.Column="0"
                                                                     Spacing="2">
                                                    <Label Text="{Binding Name}"
                                                           TextColor="#1E1B4B"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding DepartmentName}"
                                                           TextColor="#64748B"
                                                           FontSize="11"
                                                           LineBreakMode="TailTruncation" />
                                                </VerticalStackLayout>

                                                <CheckBox Grid.Column="1"
                                                          IsChecked="{Binding IsSelected}"
                                                          Color="#4F46E5"
                                                          VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Button Grid.Column="0"
                                        Text="Grup Oluştur"
                                        Command="{Binding CreateGroupCommand}"
                                        BackgroundColor="#4F46E5"
                                        TextColor="White"
                                        CornerRadius="4"
                                        HeightRequest="46" />

                                <ActivityIndicator Grid.Column="1"
                                                   WidthRequest="24"
                                                   HeightRequest="24"
                                                   IsRunning="{Binding IsCreatingGroup}"
                                                   IsVisible="{Binding IsCreatingGroup}"
                                                   Color="#4F46E5"
                                                   VerticalOptions="Center" />
                            </Grid>

                            <Label Text="{Binding GroupCreationStatus}"
                                   TextColor="#107C10"
                                   FontSize="11"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Divider -->
                    <BoxView Color="#E0E0E0"
                             HeightRequest="1"
                             HorizontalOptions="Fill" />

                    <!-- Group Deletion Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <!-- Section Header with blue bar -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <BoxView Grid.Column="0" Color="#A4262C" WidthRequest="4" HeightRequest="22" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="Grup Silme"
                                           TextColor="#1E1B4B"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding GroupDeleteHelperText}"
                                           TextColor="#94A3B8"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="10,4">
                                <Picker ItemsSource="{Binding AvailableGroups}"
                                        SelectedItem="{Binding SelectedGroupToDelete}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        Title="Grup seç"
                                        TitleColor="#94A3B8"
                                        TextColor="#1E1B4B"
                                        BackgroundColor="Transparent"
                                        IsEnabled="{Binding CanDeleteGroups}"
                                        HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Border BackgroundColor="#EEF2FF"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12"
                                    IsVisible="{Binding HasSelectedGroupToDelete}">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Departmanlar"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                    <Label Text="{Binding SelectedDeleteGroupDepartmentsText}"
                                           TextColor="#1E1B4B"
                                           FontSize="13"
                                           LineBreakMode="WordWrap" />
                                    <Label Text="Uyeler"
                                           TextColor="#94A3B8"
                                           FontSize="11" />
                                    <Label Text="{Binding SelectedDeleteGroupMembersText}"
                                           TextColor="#1E1B4B"
                                           FontSize="13"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Button Grid.Column="0"
                                        Text="Grubu Sil"
                                        Command="{Binding DeleteSelectedGroupCommand}"
                                        IsEnabled="{Binding CanUseDeleteGroupForm}"
                                        BackgroundColor="#A4262C"
                                        TextColor="White"
                                        CornerRadius="4"
                                        HeightRequest="46" />

                                <ActivityIndicator Grid.Column="1"
                                                   WidthRequest="24"
                                                   HeightRequest="24"
                                                   IsRunning="{Binding IsDeletingGroup}"
                                                   IsVisible="{Binding IsDeletingGroup}"
                                                   Color="#A4262C"
                                                   VerticalOptions="Center" />
                            </Grid>

                            <Label Text="{Binding GroupDeletionStatus}"
                                   TextColor="#A4262C"
                                   FontSize="11"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding ShowReportsNavigation}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding ShowManagementNavigation}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="2"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem="Leader"
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>
