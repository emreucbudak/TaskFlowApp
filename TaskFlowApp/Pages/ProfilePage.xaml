<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.ProfilePage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Blue Header with back button -->
        <Grid Grid.Row="0"
              Padding="16,12,16,12"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#4F46E5">
            <Border Grid.Column="0"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateBackCommand}" />
                </Border.GestureRecognizers>
                <Image Source="{mi:MaterialOutlined Icon=ArrowBack}"
                       WidthRequest="20"
                       HeightRequest="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="Profilim"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <!-- Avatar: white circle with blue initials -->
            <Border Grid.Column="2"
                    BackgroundColor="White"
                    Stroke="Transparent"
                    WidthRequest="36"
                    HeightRequest="36"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="{Binding Initials}"
                       TextColor="#4F46E5"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,14,20,20"
                                 Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12" />

                <!-- User Info Card -->
                <Border BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">
                        <!-- Avatar circle: blue with white initials -->
                        <Border BackgroundColor="#4F46E5"
                                Stroke="Transparent"
                                WidthRequest="60"
                                HeightRequest="60">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30" />
                            </Border.StrokeShape>
                            <Label Text="{Binding Initials}"
                                   TextColor="White"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
                            <Label Text="{Binding DisplayName}"
                                   TextColor="#1E1B4B"
                                   FontSize="22"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding RoleTitle}"
                                   TextColor="#4F46E5"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Subtitle}"
                                   TextColor="#64748B"
                                   FontSize="12"
                                   IsVisible="{Binding HasSubtitle}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Section Header: Hesap Ozeti -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Hesap &#214;zeti" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                    <!-- Primary Metric Card -->
                    <Border Grid.Column="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#4F46E5" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="6">
                                <Label Text="{Binding PrimaryMetricTitle}"
                                       TextColor="#64748B"
                                       FontSize="12" />
                                <Label Text="{Binding PrimaryMetricValue}"
                                       TextColor="#1E1B4B"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Secondary Metric Card -->
                    <Border Grid.Column="1"
                            BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#107C10" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="6">
                                <Label Text="{Binding SecondaryMetricTitle}"
                                       TextColor="#64748B"
                                       FontSize="12" />
                                <Label Text="{Binding SecondaryMetricValue}"
                                       TextColor="#1E1B4B"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Section Header: Detaylar -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Detaylar" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <Label Text="{Binding DetailEmptyMessage}"
                       TextColor="#94A3B8"
                       FontSize="12"
                       IsVisible="{Binding HasNoDetails}" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding DetailItems}"
                                     IsVisible="{Binding HasDetails}"
                                     Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,10">
                                <Border.Shadow>
                                    <Shadow Brush="#204F46E5" Offset="0,1" Radius="4" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">
                                    <Label Text="{Binding Title}"
                                           TextColor="#64748B"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           VerticalOptions="Start" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Value}"
                                           TextColor="#1E1B4B"
                                           FontSize="12"
                                           LineBreakMode="WordWrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <controls:AppBottomNav Grid.Row="2"
                               ActiveItem="Profile" />

        <controls:ProfileDrawer Grid.RowSpan="3"
                                ActiveItem="Profile"
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
