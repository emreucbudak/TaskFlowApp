<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.CompanyEmployeesPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Label Grid.Column="0" Text="TaskFlow" FontSize="20" FontAttributes="Bold" TextColor="#1E1B4B" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="36" HeightRequest="36" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- SCROLL CONTENT -->
        <Grid Grid.Row="1">
            <ScrollView>
                <VerticalStackLayout Padding="16,12,16,24" Spacing="12">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#A4262C"
                           FontSize="12"
                           HeightRequest="18"
                           VerticalTextAlignment="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                        <!-- LEFT COLUMN -->
                        <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto" RowSpacing="0" VerticalOptions="Fill">

                            <!-- Add Worker Form -->
                            <Border Grid.Row="0" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="14,12" VerticalOptions="Start">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="18" VerticalOptions="Center" CornerRadius="2" />
                                        <Label Grid.Column="1" Text="Çalışan Ekle" FontSize="15" FontAttributes="Bold" TextColor="#1E1B4B" />
                                    </Grid>

                                    <BoxView Color="#E0E7FF" HeightRequest="1" HorizontalOptions="Fill" />

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="4,0">
                                        <Entry Placeholder="Ad Soyad"
                                               Text="{Binding WorkerNameInput}"
                                               TextColor="#1E1B4B"
                                               PlaceholderColor="#94A3B8"
                                               BackgroundColor="Transparent"
                                               FontSize="13"
                                               HeightRequest="40" />
                                    </Border>

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="4,0">
                                        <Entry Placeholder="E-posta"
                                               Text="{Binding WorkerEmailInput}"
                                               Keyboard="Email"
                                               TextColor="#1E1B4B"
                                               PlaceholderColor="#94A3B8"
                                               BackgroundColor="Transparent"
                                               FontSize="13"
                                               HeightRequest="40" />
                                    </Border>

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="4,0">
                                        <Entry Placeholder="Şifre"
                                               Text="{Binding WorkerPasswordInput}"
                                               IsPassword="True"
                                               TextColor="#1E1B4B"
                                               PlaceholderColor="#94A3B8"
                                               BackgroundColor="Transparent"
                                               FontSize="13"
                                               HeightRequest="40" />
                                    </Border>

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="8,0">
                                        <Grid HeightRequest="40" VerticalOptions="Center">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDepartmentSelectTapped" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                                <Label Grid.Column="0"
                                                       Text="{Binding SelectedDepartmentDisplayText}"
                                                       TextColor="#1E1B4B"
                                                       VerticalOptions="Center"
                                                       FontSize="13" />
                                                <Path Grid.Column="1"
                                                      Data="M 2 4 L 7 9 L 12 4"
                                                      Stroke="#94A3B8"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      WidthRequest="14"
                                                      HeightRequest="10"
                                                      HorizontalOptions="End"
                                                      VerticalOptions="Center"
                                                      Margin="8,0,0,0" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Button Text="Çalışan Ekle"
                                            Command="{Binding AddWorkerCommand}"
                                            BackgroundColor="#4F46E5"
                                            TextColor="White"
                                            CornerRadius="4"
                                            HeightRequest="40"
                                            FontSize="13"
                                            FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Change Password Form -->
                            <Border Grid.Row="2" BackgroundColor="#FFFFFF" Margin="0,12,0,0" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="14,12" VerticalOptions="End">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="18" VerticalOptions="Center" CornerRadius="2" />
                                        <Label Grid.Column="1" Text="Çalışan Şifresi Değiştir" FontSize="15" FontAttributes="Bold" TextColor="#1E1B4B" />
                                    </Grid>

                                    <BoxView Color="#E0E7FF" HeightRequest="1" HorizontalOptions="Fill" />

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="8,0">
                                        <Grid HeightRequest="40" VerticalOptions="Center">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPasswordUserSelectTapped" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                                <Label Grid.Column="0"
                                                       Text="{Binding SelectedPasswordUserDisplayText}"
                                                       TextColor="#1E1B4B"
                                                       VerticalOptions="Center"
                                                       FontSize="13" />
                                                <Path Grid.Column="1"
                                                      Data="M 2 4 L 7 9 L 12 4"
                                                      Stroke="#94A3B8"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      WidthRequest="14"
                                                      HeightRequest="10"
                                                      HorizontalOptions="End"
                                                      VerticalOptions="Center"
                                                      Margin="8,0,0,0" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="4,0">
                                        <Entry Placeholder="Yeni Şifre"
                                               Text="{Binding NewPasswordInput}"
                                               IsPassword="True"
                                               TextColor="#1E1B4B"
                                               PlaceholderColor="#94A3B8"
                                               BackgroundColor="Transparent"
                                               FontSize="13"
                                               HeightRequest="40" />
                                    </Border>

                                    <Label Text="Şifre: en az 8 karakter, büyük harf, küçük harf ve rakam içermeli."
                                           FontSize="12"
                                           TextColor="#94A3B8" />

                                    <Button Text="Şifreyi Güncelle"
                                            Command="{Binding ChangeWorkerPasswordCommand}"
                                            BackgroundColor="#4F46E5"
                                            TextColor="White"
                                            CornerRadius="4"
                                            HeightRequest="40"
                                            FontSize="13"
                                            FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- RIGHT COLUMN -->
                        <VerticalStackLayout Grid.Column="1" Spacing="12">

                            <!-- Transfer Worker Form -->
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="14,12" VerticalOptions="Start">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="18" VerticalOptions="Center" CornerRadius="2" />
                                        <Label Grid.Column="1" Text="Çalışan Transfer Et" FontSize="15" FontAttributes="Bold" TextColor="#1E1B4B" />
                                    </Grid>

                                    <BoxView Color="#E0E7FF" HeightRequest="1" HorizontalOptions="Fill" />

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="8,0">
                                        <Grid HeightRequest="40" VerticalOptions="Center">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnUserSelectTapped" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                                <Label Grid.Column="0"
                                                       Text="{Binding SelectedUserDisplayText}"
                                                       TextColor="#1E1B4B"
                                                       VerticalOptions="Center"
                                                       FontSize="13" />
                                                <Path Grid.Column="1"
                                                      Data="M 2 4 L 7 9 L 12 4"
                                                      Stroke="#94A3B8"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      WidthRequest="14"
                                                      HeightRequest="10"
                                                      HorizontalOptions="End"
                                                      VerticalOptions="Center"
                                                      Margin="8,0,0,0" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="8,0">
                                        <Grid HeightRequest="40" VerticalOptions="Center">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTransferDepartmentSelectTapped" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                                <Label Grid.Column="0"
                                                       Text="{Binding SelectedTransferDepartmentDisplayText}"
                                                       TextColor="#1E1B4B"
                                                       VerticalOptions="Center"
                                                       FontSize="13" />
                                                <Path Grid.Column="1"
                                                      Data="M 2 4 L 7 9 L 12 4"
                                                      Stroke="#94A3B8"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      WidthRequest="14"
                                                      HeightRequest="10"
                                                      HorizontalOptions="End"
                                                      VerticalOptions="Center"
                                                      Margin="8,0,0,0" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Button Text="Transfer Et"
                                            Command="{Binding TransferUserCommand}"
                                            BackgroundColor="#4F46E5"
                                            TextColor="White"
                                            CornerRadius="4"
                                            HeightRequest="40"
                                            FontSize="13"
                                            FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Add Department Form -->
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="14,12" VerticalOptions="Start">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="18" VerticalOptions="Center" CornerRadius="2" />
                                        <Label Grid.Column="1" Text="Departman Ekle" FontSize="15" FontAttributes="Bold" TextColor="#1E1B4B" />
                                    </Grid>

                                    <BoxView Color="#E0E7FF" HeightRequest="1" HorizontalOptions="Fill" />

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="4,0">
                                        <Entry Placeholder="Departman Adı (2-10)"
                                               Text="{Binding DepartmentNameInput}"
                                               TextColor="#1E1B4B"
                                               PlaceholderColor="#94A3B8"
                                               BackgroundColor="Transparent"
                                               FontSize="13"
                                               HeightRequest="40" />
                                    </Border>

                                    <Button Text="Departman Ekle"
                                            Command="{Binding AddDepartmentCommand}"
                                            BackgroundColor="#4F46E5"
                                            TextColor="White"
                                            CornerRadius="4"
                                            HeightRequest="40"
                                            FontSize="13"
                                            FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Delete Worker Form -->
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="14,12" VerticalOptions="Start">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <BoxView Color="#A4262C" WidthRequest="4" HeightRequest="18" VerticalOptions="Center" CornerRadius="2" />
                                        <Label Grid.Column="1" Text="Çalışan Sil" FontSize="15" FontAttributes="Bold" TextColor="#1E1B4B" />
                                    </Grid>

                                    <BoxView Color="#E0E7FF" HeightRequest="1" HorizontalOptions="Fill" />

                                    <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 4" Stroke="#C7D2FE" Padding="8,0">
                                        <Grid HeightRequest="40" VerticalOptions="Center">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDeleteUserSelectTapped" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                                <Label Grid.Column="0"
                                                       Text="{Binding SelectedDeleteUserDisplayText}"
                                                       TextColor="#1E1B4B"
                                                       VerticalOptions="Center"
                                                       FontSize="13" />
                                                <Path Grid.Column="1"
                                                      Data="M 2 4 L 7 9 L 12 4"
                                                      Stroke="#94A3B8"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      WidthRequest="14"
                                                      HeightRequest="10"
                                                      HorizontalOptions="End"
                                                      VerticalOptions="Center"
                                                      Margin="8,0,0,0" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Button Text="Çalışan Sil"
                                            Command="{Binding RemoveWorkerCommand}"
                                            BackgroundColor="#A4262C"
                                            TextColor="White"
                                            CornerRadius="4"
                                            HeightRequest="40"
                                            FontSize="13"
                                            FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>

            <ActivityIndicator
                Grid.ZIndex="1"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#4F46E5"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Grid>

        <!-- HIDDEN OLD NAV -->
        <Grid Grid.Row="2" IsVisible="False"
              ColumnDefinitions="*,*,*,*,*,*"
              BackgroundColor="#FFFFFF"
              Padding="0,8,0,20">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="40" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="40" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ManageAccounts}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="3" CornerRadius="1.5" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="40" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Subscriptions}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="40" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="40" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="40" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </Grid>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="Secondary" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem=""
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
