<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Name="SubscriptionsPage"
             x:Class="TaskFlowApp.Pages.CompanySubscriptionsPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16,20,20" Spacing="16">
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#4F46E5" />

                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#A4262C"
                    FontSize="12" />

                <!-- Active Plan Card -->
                <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                    <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <Grid BackgroundColor="#4F46E5" Padding="16,12">
                            <Label Text="Aktif Plan" FontSize="20" FontAttributes="Bold" TextColor="White" />
                        </Grid>
                        <VerticalStackLayout Spacing="6" Padding="16,12">
                            <Label Text="{Binding ActivePlanName, StringFormat='Aktif plan: {0}'}" FontSize="13" TextColor="#64748B" />
                            <Label Text="{Binding ActivePlanPriceText, StringFormat='Plan ücreti: {0}'}" FontSize="13" TextColor="#64748B" />
                            <Label Text="{Binding ActivePlanStartDateText, StringFormat='Güncel abonelik başlangıç tarihi: {0}'}" FontSize="13" TextColor="#64748B" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Plan Usage Table -->
                <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="16,14">
                    <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" VerticalOptions="Center" CornerRadius="2" />
                            <Label Grid.Column="1" Text="Plan Hakları ve Kalan Kullanım" FontSize="18" FontAttributes="Bold" TextColor="#1E1B4B" />
                        </Grid>

                        <!-- Table Header -->
                        <Grid ColumnDefinitions="2*,*,*,*" BackgroundColor="#EEF2FF" Padding="8,6,8,6">
                            <Label Grid.Column="0" Text="Özellik" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" />
                            <Label Grid.Column="1" Text="Limit" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="Kullanım" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Kalan" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding PlanUsageRows}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*,*,*,*" Padding="8,6,8,6">
                                        <Label Grid.Column="0" Text="{Binding Feature}" FontSize="12" TextColor="#64748B" />
                                        <Label Grid.Column="1" Text="{Binding Limit}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Limit}" Value="&#x2713;">
                                                    <Setter Property="TextColor" Value="#107C10" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Grid.Column="2" Text="{Binding Usage}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Usage}" Value="&#x2713;">
                                                    <Setter Property="TextColor" Value="#107C10" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Grid.Column="3" Text="{Binding Remaining}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Remaining}" Value="&#x2713;">
                                                    <Setter Property="TextColor" Value="#107C10" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Plan Comparison / Change Plan -->
                <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="16,14">
                    <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" VerticalOptions="Center" CornerRadius="2" />
                            <Label Grid.Column="1" Text="Plan Değiştir" FontSize="18" FontAttributes="Bold" TextColor="#1E1B4B" />
                        </Grid>

                        <Label Text="Uyarı: Planınızı değiştirirseniz önceki verileriniz silinir." FontSize="12" TextColor="#A4262C" />
                        <Label Text="{Binding PendingPaymentPlanName, StringFormat='Ödeme doğrulaması bekleniyor: {0}'}"
                               IsVisible="{Binding IsAwaitingPaymentConfirmation}"
                               FontSize="12"
                               TextColor="#4F46E5" />

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <VerticalStackLayout Spacing="6">
                                <!-- Table Header -->
                                <Grid ColumnDefinitions="1.7*,1.2*,1*,1*,1.4*,1.1*,1.2*"
                                      MinimumWidthRequest="760"
                                      BackgroundColor="#EEF2FF"
                                      Padding="8,6,8,6">
                                    <Label Grid.Column="0" Text="Plan" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" />
                                    <Label Grid.Column="1" Text="Ücret" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="2" Text="Kullanıcı" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="3" Text="Takım" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4" Text="Bireysel Görev" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="5" Text="İç Raporlama" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="6" Text="İşlem" FontSize="12" FontAttributes="Bold" TextColor="#1E1B4B" HorizontalTextAlignment="Center" />
                                </Grid>

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding PlanSelectionRows}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="1.7*,1.2*,1*,1*,1.4*,1.1*,1.2*"
                                                  MinimumWidthRequest="760"
                                                  Padding="8,6,8,6">
                                                <Label Grid.Column="0" Text="{Binding PlanName}" FontSize="12" TextColor="#64748B" />
                                                <Label Grid.Column="1" Text="{Binding Price}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                                <Label Grid.Column="2" Text="{Binding UserLimit}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                                <Label Grid.Column="3" Text="{Binding TeamLimit}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                                <Label Grid.Column="4" Text="{Binding IndividualTaskLimit}" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                                <Label Grid.Column="5" Text="{Binding InternalReporting}" FontSize="12" TextColor="#107C10" HorizontalTextAlignment="Center" />
                                                <Button Grid.Column="6"
                                                        Text="{Binding ActionButtonText}"
                                                        Command="{Binding BindingContext.SelectPlanCommand, Source={x:Reference SubscriptionsPage}}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding IsSelectable}"
                                                        BackgroundColor="{Binding ActionButtonColor}"
                                                        TextColor="White"
                                                        CornerRadius="4"
                                                        HeightRequest="34"
                                                        FontSize="12" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

                <!-- Cancel / Resume Subscription -->
                <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="16,14">
                    <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding SubscriptionActionTitle}" FontSize="20" FontAttributes="Bold" TextColor="#1E1B4B" />
                        <Button Text="{Binding SubscriptionActionButtonText}"
                                Command="{Binding CancelSubscriptionCommand}"
                                BackgroundColor="{Binding SubscriptionActionButtonColor}"
                                TextColor="White"
                                CornerRadius="4"
                                HeightRequest="42" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- HIDDEN OLD NAV -->
        <Grid Grid.Row="2" IsVisible="False"
              ColumnDefinitions="*,*,*,*,*,*"
              BackgroundColor="#FFFFFF"
              Padding="0,6,0,18">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ManageAccounts}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Subscriptions}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="3" CornerRadius="1.5" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </Grid>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="Notifications" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem=""
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
