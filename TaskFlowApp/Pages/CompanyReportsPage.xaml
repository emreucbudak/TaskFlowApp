<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.CompanyReportsPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16,20,20" Spacing="16">
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#4F46E5" />

                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#A4262C"
                    FontSize="12" />

                <!-- Section Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" VerticalOptions="Center" CornerRadius="2" />
                    <Label Grid.Column="1" Text="Raporlar" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <CollectionView ItemsSource="{Binding Reports}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="Rapor bulunamadı." FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" Margin="0,10,0,0" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <Grid ColumnDefinitions="4,*">
                                    <!-- Left accent strip -->
                                    <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" HorizontalOptions="Start" VerticalOptions="Fill" />
                                    <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="8">
                                        <Label Text="{Binding Title}" TextColor="#1E1B4B" FontSize="15" FontAttributes="Bold" />
                                        <Label Text="{Binding Description}" TextColor="#64748B" FontSize="12" LineBreakMode="TailTruncation" MaxLines="2" Margin="0,0,0,6" />

                                        <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Center" JustifyContent="Start">
                                            <!-- Created date pill -->
                                            <Border BackgroundColor="#E0E7FF" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="8,4" Margin="0,0,6,6">
                                                <Label Text="{Binding CreatedAt, StringFormat='Oluşturma: {0:dd.MM.yyyy HH:mm}'}" TextColor="#4F46E5" FontSize="11" />
                                            </Border>
                                            <!-- Status pill -->
                                            <Border BackgroundColor="#DFF6DD" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="8,4" Margin="0,0,6,6">
                                                <Label Text="{Binding ReportStatusName, StringFormat='Durum: {0}'}" TextColor="#107C10" FontSize="11" />
                                            </Border>
                                            <!-- Topic pill -->
                                            <Border BackgroundColor="#F0F0FF" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="8,4" Margin="0,0,6,6">
                                                <Label Text="{Binding ReportTopicName, StringFormat='Konu: {0}'}" TextColor="#5B5FC7" FontSize="11" />
                                            </Border>
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- PAGINATION BAR -->
        <Border Grid.Row="2"
                Margin="20,8,20,8"
                BackgroundColor="#FFFFFF"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 4"
                Padding="12">
            <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text=""
                        ImageSource="{mi:MaterialOutlined Icon=ArrowBack, IconColor=#FFFFFF}"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoPrevious}"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="36"
                        WidthRequest="44"
                        Padding="0" />
                <Label Grid.Column="1"
                       Text="{Binding PageInfoText}"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#64748B"
                       FontSize="13" />
                <Button Grid.Column="2"
                        Text=""
                        ImageSource="{mi:MaterialOutlined Icon=ArrowForward, IconColor=#FFFFFF}"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNext}"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="36"
                        WidthRequest="44"
                        Padding="0" />
            </Grid>
        </Border>

        <!-- HIDDEN OLD NAV -->
        <Grid Grid.Row="4" IsVisible="False"
              ColumnDefinitions="*,*,*,*,*,*"
              BackgroundColor="#FFFFFF"
              Padding="0,6,0,18">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ManageAccounts}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Subscriptions}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="3" CornerRadius="1.5" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8" Stroke="Transparent" WidthRequest="38" HeightRequest="28" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </Grid>

        <controls:AppBottomNav Grid.Row="5"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="6"
                                ActiveItem="Reports"
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
