<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.ReportsPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- Section Header -->
        <Grid Grid.Row="1" Padding="20,16,20,4" ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" CornerRadius="2" VerticalOptions="Fill" />
            <Label Grid.Column="1"
                   Text="Raporlar"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#1E1B4B"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,10,20,20" Spacing="14">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12" />

                <!-- No access warning -->
                <Border BackgroundColor="#FDE7E9"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="14"
                        IsVisible="{Binding HasNoReportAccess}">
                    <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                    <Label Text="{Binding AccessMessage}"
                           TextColor="#A4262C"
                           FontSize="13"
                           LineBreakMode="WordWrap" />
                </Border>

                <!-- Reports list -->
                <CollectionView ItemsSource="{Binding Reports}"
                                SelectionMode="None"
                                IsVisible="{Binding HasReportAccess}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="{Binding EmptyReportsMessage}"
                               FontSize="12"
                               TextColor="#94A3B8"
                               HorizontalTextAlignment="Center"
                               Margin="0,10,0,0" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                                <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                                <Grid ColumnDefinitions="4,*">
                                    <BoxView Grid.Column="0" Color="#4F46E5" CornerRadius="4,0,0,4" />
                                    <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="8">
                                        <Label Text="{Binding Title}"
                                               TextColor="#1E1B4B"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Description}"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"
                                               Margin="0,0,0,4" />

                                        <FlexLayout Wrap="Wrap"
                                                    Direction="Row"
                                                    AlignItems="Center"
                                                    JustifyContent="Start">
                                            <!-- Date pill -->
                                            <Border BackgroundColor="#EEF2FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=AccessTime}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding CreatedAt, StringFormat='Oluşturma: {0:dd.MM.yyyy HH:mm}'}"
                                                           TextColor="#4F46E5"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Status pill -->
                                            <Border BackgroundColor="#DFF6DD"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Info}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding ReportStatusName, StringFormat='Durum: {0}'}"
                                                           TextColor="#107C10"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>

                                            <!-- Topic pill -->
                                            <Border BackgroundColor="#F0F0FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    Margin="0,0,6,6">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Image Grid.Column="0"
                                                           Source="{mi:MaterialOutlined Icon=Category}"
                                                           WidthRequest="12"
                                                           HeightRequest="12"
                                                           Aspect="AspectFit"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding ReportTopicName, StringFormat='Konu: {0}'}"
                                                           TextColor="#5B5FC7"
                                                           FontSize="11" />
                                                </Grid>
                                            </Border>
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Pagination -->
        <Border Grid.Row="3"
                Margin="20,8,20,8"
                BackgroundColor="#FFFFFF"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 4"
                Padding="12"
                IsVisible="{Binding HasReportAccess}">
            <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text=""
                        ImageSource="{mi:MaterialOutlined Icon=ArrowBack}"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoPrevious}"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="36"
                        WidthRequest="44"
                        Padding="0" />
                <Label Grid.Column="1"
                       Text="{Binding PageInfoText}"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#64748B"
                       FontSize="13" />
                <Button Grid.Column="2"
                        Text=""
                        ImageSource="{mi:MaterialOutlined Icon=ArrowForward}"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNext}"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="36"
                        WidthRequest="44"
                        Padding="0" />
            </Grid>
        </Border>

        <!-- Hidden FlexLayout Nav -->
        <FlexLayout Grid.Row="4" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="6"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="5"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="6"
                                ActiveItem="Reports"
                                IsOpen="{Binding IsProfileMenuOpen}" />
    </Grid>
</ContentPage>
