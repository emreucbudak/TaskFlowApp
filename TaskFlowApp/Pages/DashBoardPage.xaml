<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="TaskFlowApp.Pages.DashBoardPage"
             BackgroundColor="#0D1B2A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid Grid.Row="0"
              Padding="20,16,20,10"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#0D1B2A">
            <Image Grid.Column="0"
                   Source="https://www.logoai.com/uploads/icon/2021/08/06/732ca933-7df8-43e8-b085-69466243c919.png"
                   WidthRequest="32"
                   HeightRequest="32"
                   Aspect="AspectFit"
                   VerticalOptions="Center" />

            <Grid Grid.Column="2"
                  WidthRequest="44"
                  HeightRequest="44"
                  HorizontalOptions="End"
                  VerticalOptions="Center">
                <Ellipse WidthRequest="44"
                         HeightRequest="44"
                         Stroke="#3A5068"
                         StrokeThickness="1.5"
                         Fill="#1A3A5C"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

                <Grid WidthRequest="44"
                      HeightRequest="44"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Ellipse WidthRequest="16"
                             HeightRequest="16"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Margin="0,10,0,0" />
                    <Ellipse WidthRequest="28"
                             HeightRequest="20"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,2" />
                </Grid>

                <Ellipse WidthRequest="12"
                         HeightRequest="12"
                         Fill="#4CAF50"
                         Stroke="#0D1B2A"
                         StrokeThickness="2"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="0,0,1,1" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,14,20,20" Spacing="16">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#f87171"
                    FontSize="12" />

                <Label Text="Ki&#351;isel &#304;statistikler"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="2,0,0,0" />

                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      RowSpacing="10">
                    <Border Grid.Row="0"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Atanan Bireysel G&#246;rev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding IndividualTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Atanan Grup G&#246;revi" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding GroupTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Toplam Tamamlanan G&#246;rev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding TotalCompleted}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Toplam Geciken G&#246;rev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding OverdueTasks}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Tamamlanan Bireysel G&#246;rev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding CompletedIndividualTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Tamamlanan Grup G&#246;revi" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding CompletedGroupTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Geciken Bireysel G&#246;rev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding OverdueIndividualTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Geciken Grup G&#246;revi" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding OverdueGroupTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Okunmam&#305;&#351; Mesaj" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding UnreadMessageCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12"
                      Margin="2,6,0,0">
                    <Label Grid.Column="0"
                           Text="Grubun Son Aktiviteleri"
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="T&#252;m&#252;n&#252; G&#246;r"
                            Command="{Binding ShowAllGroupRecentActivitiesCommand}"
                            IsEnabled="{Binding CanShowAllGroupRecentActivities}"
                            BackgroundColor="#1A3A5C"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="28"
                            Padding="12,4"
                            FontSize="12" />
                </Grid>
                <Border BackgroundColor="#0F2338"
                        Stroke="#2E4A67"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="{Binding GroupActivityEmptyMessage}"
                               TextColor="#B8C6D6"
                               FontSize="13"
                               IsVisible="{Binding HasNoGroupRecentActivities}" />

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding GroupRecentActivities}"
                                             IsVisible="{Binding HasGroupRecentActivities}"
                                             Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#0F2338"
                                            Stroke="#2E4A67"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,8">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8"
                                              RowSpacing="2">
                                            <Label Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding ActorName}"
                                                   TextColor="White"
                                                   FontSize="13"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding OccurredAtText}"
                                                   TextColor="#8FA6BE"
                                                   FontSize="11" />
                                            <Label Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding ActionText}"
                                                   TextColor="#D4E2F0"
                                                   FontSize="12"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Label Text="G&#252;n&#252;n &#214;zeti"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="2,6,0,0" />

                <Border BackgroundColor="#0F2338"
                        Stroke="#34506C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14">
                    <Label Text="{Binding DailySummaryText}"
                           TextColor="#D4E2F0"
                           FontSize="12"
                           LineBreakMode="WordWrap" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="3"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <FlexLayout Grid.Row="4"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#0F1E2D"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#2196F3"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>
    </Grid>
</ContentPage>


