<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="TaskFlowApp.Pages.DashBoardPage"
             BackgroundColor="#0D1B2A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid Grid.Row="0"
              Padding="20,16,20,10"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#0D1B2A">
            <Image Grid.Column="0"
                   Source="https://www.logoai.com/uploads/icon/2021/08/06/732ca933-7df8-43e8-b085-69466243c919.png"
                   WidthRequest="32"
                   HeightRequest="32"
                   Aspect="AspectFit"
                   VerticalOptions="Center" />

            <Grid Grid.Column="2"
                  WidthRequest="44"
                  HeightRequest="44"
                  HorizontalOptions="End"
                  VerticalOptions="Center">
                <Ellipse WidthRequest="44"
                         HeightRequest="44"
                         Stroke="#3A5068"
                         StrokeThickness="1.5"
                         Fill="#1A3A5C"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

                <Grid WidthRequest="44"
                      HeightRequest="44"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Ellipse WidthRequest="16"
                             HeightRequest="16"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Margin="0,10,0,0" />
                    <Ellipse WidthRequest="28"
                             HeightRequest="20"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,2" />
                </Grid>

                <Ellipse WidthRequest="12"
                         HeightRequest="12"
                         Fill="#4CAF50"
                         Stroke="#0D1B2A"
                         StrokeThickness="2"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="0,0,1,1" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,14,20,20" Spacing="16">
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#2196F3" />

                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#f87171"
                    FontSize="12" />

                <Label Text="Kişisel İstatistikler"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="2,0,0,0" />

                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      RowSpacing="10">
                    <Border Grid.Row="0"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Atanan Bireysel Görev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding IndividualTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Atanan Grup Görevi" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding GroupTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Toplam Tamamlanan Görev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding TotalCompleted}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Toplam Geciken Görev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding OverdueTasks}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Tamamlanan Bireysel Görev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding CompletedIndividualTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Tamamlanan Grup Görevi" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding CompletedGroupTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="0"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Geciken Bireysel Görev" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding OverdueIndividualTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="1"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Geciken Grup Görevi" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding OverdueGroupTaskCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Okunmamış Mesaj" TextColor="#B8C6D6" FontSize="12" />
                            <Label Text="{Binding UnreadMessageCount}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="Grubun Son Aktivitileri"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="2,6,0,0" />

                <Border BackgroundColor="#0F2338"
                        Stroke="#2E4A67"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding CurrentGroupName, StringFormat='Grup: {0}'}"
                               TextColor="#B8C6D6"
                               FontSize="12"
                               IsVisible="{Binding HasUserGroup}" />

                        <Label Text="{Binding GroupActivityEmptyMessage}"
                               TextColor="#B8C6D6"
                               FontSize="13"
                               IsVisible="{Binding HasNoGroupRecentActivities}" />

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding GroupRecentActivities}"
                                             IsVisible="{Binding HasGroupRecentActivities}"
                                             Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#122A41"
                                            Stroke="#2E4A67"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,8">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8"
                                              RowSpacing="2">
                                            <Label Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding ActorName}"
                                                   TextColor="White"
                                                   FontSize="13"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding OccurredAtText}"
                                                   TextColor="#8FA6BE"
                                                   FontSize="11" />
                                            <Label Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding ActionText}"
                                                   TextColor="#D4E2F0"
                                                   FontSize="12"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Günün Özeti"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="2,6,0,0" />

                <Border BackgroundColor="#0F2338"
                        Stroke="#34506C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14">
                    <Label Text="{Binding DailySummaryText}"
                           TextColor="#D4E2F0"
                           FontSize="12"
                           LineBreakMode="WordWrap" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="3"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <Grid Grid.Row="4"
              ColumnDefinitions="*,*,*,*,*,*"
              BackgroundColor="#0F1E2D"
              Padding="0,6,0,18">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="38"
                        HeightRequest="28"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#2196F3"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="38"
                        HeightRequest="28"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="38"
                        HeightRequest="28"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="38"
                        HeightRequest="28"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="38"
                        HeightRequest="28"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="3">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="38"
                        HeightRequest="28"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>