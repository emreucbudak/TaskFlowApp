<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.DashBoardPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="20,12,20,12"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#FFFFFF">
            <Image Grid.Column="0"
                   Source="taskflow_logo.png"
                   WidthRequest="32"
                   HeightRequest="32"
                   Aspect="AspectFit"
                   VerticalOptions="Center" />

            <!-- Avatar: initials circle -->
            <Border Grid.Column="2"
                    BackgroundColor="#4F46E5"
                    Stroke="Transparent"
                    WidthRequest="32"
                    HeightRequest="32"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}"
                       TextColor="White"
                       FontSize="13"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,14,20,20" Spacing="16">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#A4262C"
                    FontSize="12" />

                <!-- Section Header: Kisisel Istatistikler -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Ki&#351;isel &#304;statistikler" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      RowSpacing="10">

                    <!-- Stat Card: Atanan Bireysel Gorev -->
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#4F46E5" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Atanan Bireysel G&#246;rev" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding IndividualTaskCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stat Card: Atanan Grup Gorevi -->
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#4F46E5" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Atanan Grup G&#246;revi" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding GroupTaskCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stat Card: Tamamlanan Bireysel Gorev -->
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#107C10" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Tamamlanan Bireysel G&#246;rev" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding CompletedIndividualTaskCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stat Card: Tamamlanan Grup Gorevi -->
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#107C10" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Tamamlanan Grup G&#246;revi" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding CompletedGroupTaskCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stat Card: Geciken Bireysel Gorev -->
                    <Border Grid.Row="2" Grid.Column="0" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#A4262C" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Geciken Bireysel G&#246;rev" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding OverdueIndividualTaskCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stat Card: Geciken Grup Gorevi -->
                    <Border Grid.Row="2" Grid.Column="1" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#A4262C" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Geciken Grup G&#246;revi" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding OverdueGroupTaskCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stat Card: Okunmamis Mesaj (full width) -->
                    <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="#FFFFFF" Stroke="#E0E7FF" StrokeShape="RoundRectangle 12" Padding="0">
                        <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <BoxView Color="#FFB900" HeightRequest="3" HorizontalOptions="Fill" CornerRadius="4,4,0,0" />
                            <VerticalStackLayout Padding="14" Spacing="4">
                                <Label Text="Okunmam&#305;&#351; Mesaj" TextColor="#64748B" FontSize="12" />
                                <Label Text="{Binding UnreadMessageCount}" TextColor="#1E1B4B" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Section Header: Gunun Ozeti -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,8,0,0">
                    <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="G&#252;n&#252;n &#214;zeti" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <Border BackgroundColor="#FFFFFF"
                        Stroke="#E0E7FF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="14">
                    <Border.Shadow><Shadow Brush="#204F46E5" Offset="0,2" Radius="8" /></Border.Shadow>
                    <Label Text="{Binding DailySummaryText}"
                           TextColor="#475569"
                           FontSize="12"
                           LineBreakMode="WordWrap" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Hidden old FlexLayout nav -->
        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="Home" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem=""
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>
