<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.MessagesPage"
             x:Name="MessagesRoot"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Padding="20,12,20,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#FFFFFF">
            <Image Grid.Column="0" Source="taskflow_logo.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="#4F46E5" Stroke="Transparent" WidthRequest="32" HeightRequest="32" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1"
              Padding="20,12,20,12"
              RowDefinitions="Auto,*"
              RowSpacing="8">
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="4">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12" />
            </VerticalStackLayout>

            <Grid Grid.Row="1"
                  ColumnDefinitions="1.15*,16,2.85*">
                <!-- Left Panel - Users -->
                <Border Grid.Column="0"
                        BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="14">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto,*"
                          RowSpacing="12">
                        <!-- Department Group Creation -->
                        <Border Grid.Row="0"
                                BackgroundColor="#FFFFFF"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 4"
                                Padding="12"
                                IsVisible="{Binding IsDepartmentLeader}">
                            <Border.Shadow>
                                <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <!-- Section Header with blue bar -->
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <BoxView Grid.Column="0" Color="#4F46E5" WidthRequest="4" HeightRequest="20" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="Departman Grubu Oluştur"
                                               TextColor="#1E1B4B"
                                               FontSize="16"
                                               FontAttributes="Bold" />
                                        <Label Text="Sadece lideri olduğunuz departmandaki çalışanları seçerek grup oluşturabilirsiniz."
                                               TextColor="#94A3B8"
                                               FontSize="11" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Border BackgroundColor="#FFFFFF"
                                        Stroke="#C7D2FE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="12,8">
                                    <Entry Text="{Binding GroupNameInput}"
                                           Placeholder="Grup adı"
                                           PlaceholderColor="#94A3B8"
                                           TextColor="#1E1B4B"
                                           BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing" />
                                </Border>

                                <Border BackgroundColor="#FFFFFF"
                                        Stroke="#C7D2FE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="10,4">
                                    <Picker ItemsSource="{Binding ManagedDepartments}"
                                            SelectedItem="{Binding SelectedManagedDepartment}"
                                            ItemDisplayBinding="{Binding DepartmentName}"
                                            Title="Departman seç"
                                            TextColor="#1E1B4B"
                                            TitleColor="#94A3B8"
                                            BackgroundColor="Transparent" />
                                </Border>

                                <CollectionView ItemsSource="{Binding EligibleDepartmentUsers}"
                                                SelectionMode="None"
                                                HeightRequest="180">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Vertical"
                                                           ItemSpacing="8" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.EmptyView>
                                        <Label Text="Secilen departmanda gruba eklenebilecek calisan bulunmuyor."
                                               FontSize="11"
                                               TextColor="#94A3B8"
                                               HorizontalTextAlignment="Center"
                                               Margin="0,12,0,0" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FFFFFF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 4"
                                                    Padding="10">
                                                <Border.Shadow>
                                                    <Shadow Brush="#204F46E5" Offset="0,1" Radius="4" />
                                                </Border.Shadow>
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="10">
                                                    <VerticalStackLayout Grid.Column="0"
                                                                         Spacing="2">
                                                        <Label Text="{Binding Name}"
                                                               TextColor="#1E1B4B"
                                                               FontSize="13"
                                                               FontAttributes="Bold"
                                                               LineBreakMode="TailTruncation" />
                                                        <Label Text="{Binding DepartmentName}"
                                                               TextColor="#64748B"
                                                               FontSize="11"
                                                               LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>

                                                    <CheckBox Grid.Column="1"
                                                              IsChecked="{Binding IsSelected}"
                                                              Color="#4F46E5"
                                                              VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Button Grid.Column="0"
                                            Text="Grup Oluştur"
                                            Command="{Binding CreateDepartmentGroupCommand}"
                                            BackgroundColor="#4F46E5"
                                            TextColor="White"
                                            CornerRadius="4"
                                            HeightRequest="44" />

                                    <ActivityIndicator Grid.Column="1"
                                                       WidthRequest="24"
                                                       HeightRequest="24"
                                                       IsRunning="{Binding IsCreatingDepartmentGroup}"
                                                       IsVisible="{Binding IsCreatingDepartmentGroup}"
                                                       Color="#4F46E5"
                                                       VerticalOptions="Center" />
                                </Grid>

                                <Label Text="{Binding GroupCreationStatus}"
                                       TextColor="#107C10"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Search Bar -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <Image Grid.Column="0"
                                           Source="{mi:MaterialOutlined Icon=Search, IconColor=#94A3B8}"
                                           WidthRequest="16"
                                           HeightRequest="16"
                                           Aspect="AspectFit"
                                           VerticalOptions="Center" />
                                    <Entry Grid.Column="1"
                                           Text="{Binding SearchText}"
                                           Placeholder="&#350;irket i&#231;i kullan&#305;c&#305; ara"
                                           PlaceholderColor="#94A3B8"
                                           TextColor="#1E1B4B"
                                           BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing"
                                           VerticalOptions="Center"
                                           HandlerChanged="OnInputHandlerChanged" />
                                </Grid>
                            </Border>

                            <ActivityIndicator Grid.Column="1"
                                               WidthRequest="24"
                                               HeightRequest="24"
                                               IsRunning="{Binding IsSearchingUsers}"
                                               IsVisible="{Binding IsSearchingUsers}"
                                               Color="#4F46E5"
                                               VerticalOptions="Center" />
                        </Grid>

                        <!-- User List -->
                        <CollectionView Grid.Row="2"
                                        ItemsSource="{Binding VisibleUsers}"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.EmptyView>
                                <Label Text="{Binding UsersEmptyMessage}"
                                       FontSize="12"
                                       TextColor="#94A3B8"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,12,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FFFFFF"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 4"
                                            Padding="12">
                                        <Border.Shadow>
                                            <Shadow Brush="#204F46E5" Offset="0,1" Radius="4" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference MessagesRoot}, Path=BindingContext.SelectConversationUserCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor" Value="#EBF3FC" />
                                                <Setter Property="Stroke" Value="#4F46E5" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="10">
                                            <!-- Avatar Circle -->
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#4F46E5"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 20"
                                                    WidthRequest="40"
                                                    HeightRequest="40"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="White"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       TextColor="#1E1B4B"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding SecondaryText}"
                                                       TextColor="#64748B"
                                                       FontSize="11"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="{Binding LastActivityText}"
                                                   TextColor="#94A3B8"
                                                   FontSize="10"
                                                   VerticalOptions="Start"
                                                   HorizontalTextAlignment="End" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <!-- Right Panel - Conversation -->
                <Border Grid.Column="2"
                        BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="12">

                        <ActivityIndicator Grid.Row="0"
                                           IsRunning="{Binding IsConversationLoading}"
                                           IsVisible="{Binding IsConversationLoading}"
                                           Color="#4F46E5" />

                        <!-- Messages -->
                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding ConversationMessages}"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.EmptyView>
                                <Label Text="{Binding ConversationEmptyMessage}"
                                       FontSize="12"
                                       TextColor="#94A3B8"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,*">
                                        <!-- Other user's message (left) -->
                                        <Border Grid.Column="0"
                                                BackgroundColor="#F8FAFC"
                                                Stroke="#E0E7FF"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="12"
                                                Margin="0,0,32,0"
                                                IsVisible="True">
                                            <Border.Shadow>
                                                <Shadow Brush="#304F46E5" Offset="0,2" Radius="6" />
                                            </Border.Shadow>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsOwnMessage}"
                                                             Value="True">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding Content}"
                                                       TextColor="#1E1B4B"
                                                       FontSize="13"
                                                       LineBreakMode="WordWrap" />
                                                <Label Text="{Binding SentAtText}"
                                                       TextColor="#94A3B8"
                                                       FontSize="10" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Own message (right) -->
                                        <Grid Grid.Column="1"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8"
                                              Margin="32,0,0,0"
                                              IsVisible="False">
                                            <Grid.Triggers>
                                                <DataTrigger TargetType="Grid"
                                                             Binding="{Binding IsOwnMessage}"
                                                             Value="True">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Grid.Triggers>
                                            <Grid.GestureRecognizers>
                                                <PointerGestureRecognizer PointerEntered="OnOwnMessagePointerEntered"
                                                                          PointerExited="OnOwnMessagePointerExited" />
                                                <TapGestureRecognizer Tapped="OnOwnMessageTapped" />
                                            </Grid.GestureRecognizers>

                                            <Border Grid.Column="0"
                                                    BackgroundColor="#4F46E5"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 4"
                                                    Padding="12">
                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="{Binding Content}"
                                                           TextColor="White"
                                                           FontSize="13"
                                                           LineBreakMode="WordWrap" />
                                                    <Label Text="{Binding SentAtText}"
                                                           TextColor="#DCEEFB"
                                                           FontSize="10" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="#FFFFFF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 4"
                                                    Padding="6"
                                                    WidthRequest="32"
                                                    HeightRequest="32"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="End"
                                                    Opacity="0"
                                                    InputTransparent="True">
                                                <Border.Shadow>
                                                    <Shadow Brush="#204F46E5" Offset="0,1" Radius="4" />
                                                </Border.Shadow>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding IsDeleteVisible}"
                                                                 Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="InputTransparent" Value="False" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnDeleteMessageTapped" />
                                                </Border.GestureRecognizers>
                                                <Image Source="{mi:MaterialOutlined Icon=Delete}"
                                                       WidthRequest="16"
                                                       HeightRequest="16"
                                                       Aspect="AspectFit"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Message Input -->
                        <Grid Grid.Row="2"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="#FFFFFF"
                                    Stroke="#C7D2FE"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="12,8">
                                <Entry Text="{Binding MessageDraft}"
                                       Placeholder="Mesaj yaz"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1E1B4B"
                                       BackgroundColor="Transparent"
                                       IsEnabled="{Binding HasSelectedConversation}"
                                       ClearButtonVisibility="WhileEditing"
                                       ReturnCommand="{Binding SendMessageCommand}"
                                       HandlerChanged="OnInputHandlerChanged" />
                            </Border>

                            <Grid Grid.Column="1"
                                  WidthRequest="44"
                                  HeightRequest="44">
                                <Border BackgroundColor="#4F46E5"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SendMessageCommand}" />
                                    </Border.GestureRecognizers>
                                    <Image Source="{mi:MaterialOutlined Icon=Send}"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <ActivityIndicator IsRunning="{Binding IsSendingMessage}"
                                                   IsVisible="{Binding IsSendingMessage}"
                                                   Color="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="3" CornerRadius="1.5" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="2"
                               ActiveItem="Secondary" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem=""
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>
