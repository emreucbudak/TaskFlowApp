<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="TaskFlowApp.Pages.MessagesPage"
             x:Name="MessagesRoot"
             BackgroundColor="#0D1B2A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid Grid.Row="0"
              Padding="20,16,20,10"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#0D1B2A">
            <Image Grid.Column="0"
                   Source="https://www.logoai.com/uploads/icon/2021/08/06/732ca933-7df8-43e8-b085-69466243c919.png"
                   WidthRequest="32"
                   HeightRequest="32"
                   Aspect="AspectFit"
                   VerticalOptions="Center" />

            <Grid Grid.Column="2"
                  WidthRequest="40"
                  HeightRequest="40"
                  HorizontalOptions="End"
                  VerticalOptions="Center">
                <Ellipse WidthRequest="40"
                         HeightRequest="40"
                         Stroke="#3A5068"
                         StrokeThickness="1.5"
                         Fill="#1A3A5C"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
                <Grid WidthRequest="40"
                      HeightRequest="40"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Ellipse WidthRequest="16"
                             HeightRequest="16"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Margin="0,10,0,0" />
                    <Ellipse WidthRequest="28"
                             HeightRequest="20"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,2" />
                </Grid>
                <Ellipse WidthRequest="12"
                         HeightRequest="12"
                         Fill="#4CAF50"
                         Stroke="#0D1B2A"
                         StrokeThickness="2"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="0,0,1,1" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <Grid Grid.Row="2"
              Padding="20,8,20,12"
              RowDefinitions="Auto,*"
              RowSpacing="8">
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="4">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#2196F3" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#f87171"
                       FontSize="12" />
            </VerticalStackLayout>

            <Grid Grid.Row="1"
                  ColumnDefinitions="1.15*,16,2.85*">
                <Border Grid.Column="0"
                        BackgroundColor="#0F2338"
                        Stroke="#2E4A67"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="12">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="#162030"
                                    Stroke="#203347"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,8">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <Image Grid.Column="0"
                                           Source="{mi:MaterialOutlined Icon=Search}"
                                           WidthRequest="16"
                                           HeightRequest="16"
                                           Aspect="AspectFit"
                                           VerticalOptions="Center" />
                                    <Entry Grid.Column="1"
                                           Text="{Binding SearchText}"
                                           Placeholder="&#350;irket i&#231;i kullan&#305;c&#305; ara"
                                           PlaceholderColor="#64748b"
                                           TextColor="White"
                                           BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <ActivityIndicator Grid.Column="1"
                                               WidthRequest="24"
                                               HeightRequest="24"
                                               IsRunning="{Binding IsSearchingUsers}"
                                               IsVisible="{Binding IsSearchingUsers}"
                                               Color="#2196F3"
                                               VerticalOptions="Center" />
                        </Grid>

                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding VisibleUsers}"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.EmptyView>
                                <Label Text="{Binding UsersEmptyMessage}"
                                       FontSize="12"
                                       TextColor="#94a3b8"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,12,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#162030"
                                            Stroke="#203347"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference MessagesRoot}, Path=BindingContext.SelectConversationUserCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor" Value="#1A3A5C" />
                                                <Setter Property="Stroke" Value="#4B82B5" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="10">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#0F2D46"
                                                    Stroke="#3b82f6"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 20"
                                                    WidthRequest="40"
                                                    HeightRequest="40"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="#bfdbfe"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       TextColor="White"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding SecondaryText}"
                                                       TextColor="#94a3b8"
                                                       FontSize="11"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="{Binding LastActivityText}"
                                                   TextColor="#8DA5BD"
                                                   FontSize="10"
                                                   VerticalOptions="Start"
                                                   HorizontalTextAlignment="End" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="#0F2338"
                        Stroke="#2E4A67"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="12">

                        <ActivityIndicator Grid.Row="0"
                                           IsRunning="{Binding IsConversationLoading}"
                                           IsVisible="{Binding IsConversationLoading}"
                                           Color="#2196F3" />

                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding ConversationMessages}"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.EmptyView>
                                <Label Text="{Binding ConversationEmptyMessage}"
                                       FontSize="12"
                                       TextColor="#94a3b8"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0"
                                                BackgroundColor="#162030"
                                                Stroke="#203347"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="12"
                                                Margin="0,0,32,0"
                                                IsVisible="True">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsOwnMessage}"
                                                             Value="True">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding Content}"
                                                       TextColor="White"
                                                       FontSize="13"
                                                       LineBreakMode="WordWrap" />
                                                <Label Text="{Binding SentAtText}"
                                                       TextColor="#94a3b8"
                                                       FontSize="10" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <Border Grid.Column="1"
                                                BackgroundColor="#1A3A5C"
                                                Stroke="#4B82B5"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="12"
                                                Margin="32,0,0,0"
                                                IsVisible="False">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsOwnMessage}"
                                                             Value="True">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding Content}"
                                                       TextColor="White"
                                                       FontSize="13"
                                                       LineBreakMode="WordWrap" />
                                                <Label Text="{Binding SentAtText}"
                                                       TextColor="#dbeafe"
                                                       FontSize="10" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Grid Grid.Row="2"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="#162030"
                                    Stroke="#203347"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,8">
                                <Entry Text="{Binding MessageDraft}"
                                       Placeholder="Mesaj yaz"
                                       PlaceholderColor="#64748b"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       IsEnabled="{Binding HasSelectedConversation}"
                                       ClearButtonVisibility="WhileEditing"
                                       ReturnCommand="{Binding SendMessageCommand}" />
                            </Border>

                            <Grid Grid.Column="1"
                                  WidthRequest="44"
                                  HeightRequest="44">
                                <Border BackgroundColor="#1A3A5C"
                                        Stroke="#4B82B5"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SendMessageCommand}" />
                                    </Border.GestureRecognizers>
                                    <Image Source="{mi:MaterialOutlined Icon=Send}"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <ActivityIndicator IsRunning="{Binding IsSendingMessage}"
                                                   IsVisible="{Binding IsSendingMessage}"
                                                   Color="#dbeafe"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <BoxView Grid.Row="3"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <FlexLayout Grid.Row="4"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#0F1E2D"
                    Padding="30,10,30,24">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="HomeIconImage"
                           Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="ReportsIconImage"
                           Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="TasksIconImage"
                           Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="MessagesIconImage"
                           Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#2196F3" WidthRequest="4" HeightRequest="3" CornerRadius="1.5" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E" StrokeShape="RoundRectangle 8"
                        Stroke="Transparent" WidthRequest="42" HeightRequest="30" HorizontalOptions="Center">
                    <Image x:Name="NotificationsIconImage"
                           Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image x:Name="LogoutIconImage"
                           Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>
    </Grid>
</ContentPage>