<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.GroupDetailsPage"
             BackgroundColor="#0D1B2A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid Grid.Row="0"
              Padding="20,16,20,10"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#0D1B2A">
            <Border Grid.Column="0"
                    BackgroundColor="#162030"
                    Stroke="#2E4A67"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,6">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Label Text="Geri"
                       TextColor="White"
                       FontSize="12"
                       FontAttributes="Bold" />
            </Border>

            <Label Grid.Column="1"
                   Text="Grup Detayi"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <Grid Grid.Column="2"
                  WidthRequest="44"
                  HeightRequest="44"
                  HorizontalOptions="End"
                  VerticalOptions="Center">
                <Ellipse WidthRequest="44"
                         HeightRequest="44"
                         Stroke="#3A5068"
                         StrokeThickness="1.5"
                         Fill="#1A3A5C"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
                <Grid WidthRequest="44"
                      HeightRequest="44"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Ellipse WidthRequest="16"
                             HeightRequest="16"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Margin="0,10,0,0" />
                    <Ellipse WidthRequest="28"
                             HeightRequest="20"
                             Fill="#5B8DB8"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,2" />
                </Grid>
                <Ellipse WidthRequest="12"
                         HeightRequest="12"
                         Fill="#4CAF50"
                         Stroke="#0D1B2A"
                         StrokeThickness="2"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="0,0,1,1" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,14,20,20"
                                 Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#2196F3" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#f87171"
                       FontSize="12" />

                <Border BackgroundColor="#0F2338"
                        Stroke="#2E4A67"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16"
                        IsVisible="{Binding HasNoGroup}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Grup Bulunamadi"
                               TextColor="White"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="{Binding GroupEmptyMessage}"
                               TextColor="#94a3b8"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout IsVisible="{Binding HasGroup}"
                                     Spacing="16">
                    <Border BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="18">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding GroupName}"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding GroupDepartmentsText}"
                                   TextColor="#9FB5CB"
                                   FontSize="12" />
                            <Label Text="{Binding GroupMembersSummaryText}"
                                   TextColor="#60A5FA"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Gun Ozeti"
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold"
                           Margin="2,0,0,0" />

                    <Border BackgroundColor="#0F2338"
                            Stroke="#34506C"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <Label Text="{Binding DailySummaryText}"
                               TextColor="#D4E2F0"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </Border>

                    <Label Text="Uyeler"
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold"
                           Margin="2,0,0,0" />

                    <Label Text="{Binding MembersEmptyMessage}"
                           TextColor="#94a3b8"
                           FontSize="12"
                           IsVisible="{Binding HasNoMembers}" />

                    <ScrollView Orientation="Horizontal"
                                IsVisible="{Binding HasMembers}">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding GroupMembers}"
                                               Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#122A40"
                                            Stroke="#33506E"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="12"
                                            WidthRequest="120">
                                        <VerticalStackLayout Spacing="8"
                                                             HorizontalOptions="Center"
                                                             VerticalOptions="Center">
                                            <Border BackgroundColor="#0F2D46"
                                                    Stroke="#3b82f6"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 24"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    HorizontalOptions="Center">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="#bfdbfe"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Text="{Binding Name}"
                                                   TextColor="White"
                                                   FontSize="12"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12"
                          Margin="2,0,0,0">
                        <Label Grid.Column="0"
                               Text="Tum Aktiviteler"
                               TextColor="White"
                               FontSize="16"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding GroupMembersSummaryText}"
                               TextColor="#8FA6BE"
                               FontSize="11"
                               VerticalOptions="Center" />
                    </Grid>

                    <Border BackgroundColor="#0F2338"
                            Stroke="#2E4A67"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding ActivitiesEmptyMessage}"
                                   TextColor="#B8C6D6"
                                   FontSize="13"
                                   IsVisible="{Binding HasNoActivities}" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding GroupActivities}"
                                                 IsVisible="{Binding HasActivities}"
                                                 Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#10283D"
                                                Stroke="#2E4A67"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="12">
                                            <Grid RowDefinitions="Auto,Auto"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8"
                                                  RowSpacing="4">
                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding ActorName}"
                                                       TextColor="White"
                                                       FontSize="13"
                                                       FontAttributes="Bold" />
                                                <Label Grid.Row="0"
                                                       Grid.Column="1"
                                                       Text="{Binding OccurredAtText}"
                                                       TextColor="#8FA6BE"
                                                       FontSize="11" />
                                                <Label Grid.Row="1"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding ActionText}"
                                                       TextColor="#D4E2F0"
                                                       FontSize="12"
                                                       LineBreakMode="WordWrap" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="3"
                 Color="#1E2E3E"
                 HeightRequest="1"
                 HorizontalOptions="Fill" />

        <FlexLayout Grid.Row="4" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#0F1E2D"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#2196F3"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#1E2E3E"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>
    
        <controls:AppBottomNav Grid.Row="4"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="5"
                                ActiveItem="Group"
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>



