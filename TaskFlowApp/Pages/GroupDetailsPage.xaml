<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.GroupDetailsPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Blue Header with back button -->
        <Grid Grid.Row="0"
              Padding="16,12,16,12"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#4F46E5">
            <Border Grid.Column="0"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Image Source="{mi:MaterialOutlined Icon=ArrowBack}"
                       WidthRequest="20"
                       HeightRequest="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="Grup Detayı"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <!-- Avatar: white circle with blue initials -->
            <Border Grid.Column="2"
                    BackgroundColor="White"
                    Stroke="Transparent"
                    WidthRequest="36"
                    HeightRequest="36"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="{Binding CurrentUserInitials}"
                       TextColor="#4F46E5"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,14,20,20"
                                 Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12" />

                <!-- No Group Card -->
                <Border BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="16"
                        IsVisible="{Binding HasNoGroup}">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Grup Bulunamadı"
                               TextColor="#1E1B4B"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="{Binding GroupEmptyMessage}"
                               TextColor="#64748B"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout IsVisible="{Binding HasGroup}"
                                     Spacing="16">

                    <!-- Group Info Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding GroupName}"
                                   TextColor="#1E1B4B"
                                   FontSize="22"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding GroupDepartmentsText}"
                                   TextColor="#64748B"
                                   FontSize="12" />
                            <Label Text="{Binding GroupMembersSummaryText}"
                                   TextColor="#4F46E5"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Section Header: Uyeler -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Uyeler" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>

                    <Label Text="{Binding MembersEmptyMessage}"
                           TextColor="#94A3B8"
                           FontSize="12"
                           IsVisible="{Binding HasNoMembers}" />

                    <ScrollView Orientation="Horizontal"
                                IsVisible="{Binding HasMembers}">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding GroupMembers}"
                                               Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FFFFFF"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 4"
                                            Padding="12"
                                            WidthRequest="120">
                                        <Border.Shadow>
                                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                                        </Border.Shadow>
                                        <VerticalStackLayout Spacing="8"
                                                             HorizontalOptions="Center"
                                                             VerticalOptions="Center">
                                            <!-- Avatar: blue circle with white initials -->
                                            <Border BackgroundColor="#4F46E5"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 22"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    HorizontalOptions="Center">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="White"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Text="{Binding Name}"
                                                   TextColor="#1E1B4B"
                                                   FontSize="12"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Section Header: Aktiviteler -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Aktiviteler" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                        <!-- Add Activity Button -->
                        <Border Grid.Column="2"
                                BackgroundColor="#4F46E5"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,6"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowActivityFormCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="4">
                                <Image Source="{mi:MaterialOutlined Icon=Add}"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       VerticalOptions="Center" />
                                <Label Text="Ekle"
                                       TextColor="White"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Add Activity Form -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="#4F46E5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="16"
                            IsVisible="{Binding IsActivityFormVisible}">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Yeni Aktivite"
                                   TextColor="#1E1B4B"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#CBD5E1"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="8,4">
                                <Entry Placeholder="Aktivite basligi"
                                       Text="{Binding NewActivityTitle}"
                                       TextColor="#1E1B4B"
                                       PlaceholderColor="#94A3B8"
                                       FontSize="14" />
                            </Border>

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#CBD5E1"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="8,4">
                                <Editor Placeholder="Aciklama (istege bagli)"
                                        Text="{Binding NewActivityDescription}"
                                        TextColor="#1E1B4B"
                                        PlaceholderColor="#94A3B8"
                                        FontSize="14"
                                        HeightRequest="80"
                                        AutoSize="TextChanges" />
                            </Border>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <!-- Cancel -->
                                <Border Grid.Column="0"
                                        BackgroundColor="#F1F5F9"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,10"
                                        HorizontalOptions="Fill">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding HideActivityFormCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Iptal"
                                           TextColor="#64748B"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                </Border>
                                <!-- Submit -->
                                <Border Grid.Column="1"
                                        BackgroundColor="#4F46E5"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,10"
                                        HorizontalOptions="Fill">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SubmitActivityCommand}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                                        <ActivityIndicator IsRunning="{Binding IsSubmittingActivity}"
                                                           IsVisible="{Binding IsSubmittingActivity}"
                                                           Color="White"
                                                           WidthRequest="16"
                                                           HeightRequest="16" />
                                        <Label Text="Gonder"
                                               TextColor="White"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- No Activities Message -->
                    <Label Text="Henuz aktivite bulunmuyor."
                           TextColor="#94A3B8"
                           FontSize="12"
                           IsVisible="{Binding HasNoActivities}" />

                    <!-- Activities List -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Activities}"
                                         Spacing="10"
                                         IsVisible="{Binding HasActivities}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#FFFFFF"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="14">
                                    <Border.Shadow>
                                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                                    </Border.Shadow>
                                    <VerticalStackLayout Spacing="8">
                                        <!-- Title + Status Row -->
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   TextColor="#1E1B4B"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{Binding StatusColor}"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 10"
                                                    Padding="8,3"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding StatusText}"
                                                       TextColor="White"
                                                       FontSize="10"
                                                       FontAttributes="Bold" />
                                            </Border>
                                        </Grid>

                                        <!-- Description -->
                                        <Label Text="{Binding Description}"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               LineBreakMode="WordWrap"
                                               MaxLines="3" />

                                        <!-- Submitted by + date -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#EEF2FF"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 12"
                                                    WidthRequest="24"
                                                    HeightRequest="24"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="#4F46E5"
                                                       FontSize="9"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Grid.Column="1"
                                                   Text="{Binding SubmittedByUserName}"
                                                   TextColor="#64748B"
                                                   FontSize="11"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="2"
                                                   Text="{Binding SubmittedAtText}"
                                                   TextColor="#94A3B8"
                                                   FontSize="10"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <!-- Review Note (if exists) -->
                                        <Label Text="{Binding ReviewNoteDisplay}"
                                               TextColor="#64748B"
                                               FontSize="11"
                                               FontAttributes="Italic"
                                               IsVisible="{Binding HasReviewNote}" />

                                        <!-- Approve/Reject Buttons (only for leader, only for pending) -->
                                        <Grid ColumnDefinitions="*,*"
                                              ColumnSpacing="8"
                                              IsVisible="{Binding CanReview}">
                                            <!-- Approve -->
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#10B981"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="10,8"
                                                    HorizontalOptions="Fill">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApproveActivityCommand}"
                                                        CommandParameter="{Binding ActivityId}" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                                    <Image Source="{mi:MaterialOutlined Icon=Check}"
                                                           WidthRequest="14"
                                                           HeightRequest="14"
                                                           VerticalOptions="Center" />
                                                    <Label Text="Onayla"
                                                           TextColor="White"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>
                                            <!-- Reject -->
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#EF4444"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="10,8"
                                                    HorizontalOptions="Fill">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RejectActivityCommand}"
                                                        CommandParameter="{Binding ActivityId}" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                                    <Image Source="{mi:MaterialOutlined Icon=Close}"
                                                           WidthRequest="14"
                                                           HeightRequest="14"
                                                           VerticalOptions="Center" />
                                                    <Label Text="Reddet"
                                                           TextColor="White"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Hidden old FlexLayout nav -->
        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem="Group"
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>
