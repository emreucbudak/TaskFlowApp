<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:controls="clr-namespace:TaskFlowApp.Controls"
             x:Class="TaskFlowApp.Pages.GroupDetailsPage"
             BackgroundColor="#EEF2FF"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Blue Header with back button -->
        <Grid Grid.Row="0"
              Padding="16,12,16,12"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#4F46E5">
            <Border Grid.Column="0"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Image Source="{mi:MaterialOutlined Icon=ArrowBack}"
                       WidthRequest="20"
                       HeightRequest="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="Grup Detayı"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <!-- Avatar: white circle with blue initials -->
            <Border Grid.Column="2"
                    BackgroundColor="White"
                    Stroke="Transparent"
                    WidthRequest="36"
                    HeightRequest="36"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="KA"
                       TextColor="#4F46E5"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,14,20,20"
                                 Spacing="16">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#4F46E5" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#A4262C"
                       FontSize="12" />

                <!-- No Group Card -->
                <Border BackgroundColor="#FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 4"
                        Padding="16"
                        IsVisible="{Binding HasNoGroup}">
                    <Border.Shadow>
                        <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Grup Bulunamadı"
                               TextColor="#1E1B4B"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="{Binding GroupEmptyMessage}"
                               TextColor="#64748B"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout IsVisible="{Binding HasGroup}"
                                     Spacing="16">

                    <!-- Group Info Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="18">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding GroupName}"
                                   TextColor="#1E1B4B"
                                   FontSize="22"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding GroupDepartmentsText}"
                                   TextColor="#64748B"
                                   FontSize="12" />
                            <Label Text="{Binding GroupMembersSummaryText}"
                                   TextColor="#4F46E5"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Section Header: Gun Ozeti -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Gün Özeti" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>

                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="14">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Label Text="{Binding DailySummaryText}"
                               TextColor="#64748B"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </Border>

                    <!-- Section Header: Uyeler -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Uyeler" TextColor="#1E1B4B" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>

                    <Label Text="{Binding MembersEmptyMessage}"
                           TextColor="#94A3B8"
                           FontSize="12"
                           IsVisible="{Binding HasNoMembers}" />

                    <ScrollView Orientation="Horizontal"
                                IsVisible="{Binding HasMembers}">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding GroupMembers}"
                                               Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FFFFFF"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 4"
                                            Padding="12"
                                            WidthRequest="120">
                                        <Border.Shadow>
                                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                                        </Border.Shadow>
                                        <VerticalStackLayout Spacing="8"
                                                             HorizontalOptions="Center"
                                                             VerticalOptions="Center">
                                            <!-- Avatar: blue circle with white initials -->
                                            <Border BackgroundColor="#4F46E5"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 22"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    HorizontalOptions="Center">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="White"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Text="{Binding Name}"
                                                   TextColor="#1E1B4B"
                                                   FontSize="12"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Section Header: Tum Aktiviteler -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <BoxView Color="#4F46E5" WidthRequest="4" HeightRequest="20" CornerRadius="2" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="Tüm Aktiviteler"
                               TextColor="#1E1B4B"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="{Binding GroupMembersSummaryText}"
                               TextColor="#94A3B8"
                               FontSize="11"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Activities Card -->
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="14">
                        <Border.Shadow>
                            <Shadow Brush="#204F46E5" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding ActivitiesEmptyMessage}"
                                   TextColor="#64748B"
                                   FontSize="13"
                                   IsVisible="{Binding HasNoActivities}" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding GroupActivities}"
                                                 IsVisible="{Binding HasActivities}"
                                                 Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Timeline-style activity item -->
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="4,4">
                                            <!-- Blue dot -->
                                            <Ellipse Grid.Column="0"
                                                     WidthRequest="6"
                                                     HeightRequest="6"
                                                     Fill="#4F46E5"
                                                     VerticalOptions="Start"
                                                     Margin="0,6,0,0" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" RowSpacing="4">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding ActorName}"
                                                           TextColor="#1E1B4B"
                                                           FontSize="13"
                                                           FontAttributes="Bold" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding OccurredAtText}"
                                                           TextColor="#94A3B8"
                                                           FontSize="11" />
                                                </Grid>
                                                <Label Text="{Binding ActionText}"
                                                       TextColor="#64748B"
                                                       FontSize="12"
                                                       LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Hidden old FlexLayout nav -->
        <FlexLayout Grid.Row="2" IsVisible="False"
                    Direction="Row"
                    JustifyContent="SpaceAround"
                    AlignItems="Center"
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFFFFF"
                    Padding="18,10,18,24">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Home}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=InsertChartOutlined}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Checklist}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2"
                                 IsVisible="{Binding CanAccessReportsPage}">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLeaderTasksTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=AddCircleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=ChatBubbleOutline}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <BoxView Color="#4F46E5"
                         WidthRequest="4"
                         HeightRequest="3"
                         CornerRadius="1.5"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=NotificationsNone}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        WidthRequest="42"
                        HeightRequest="30"
                        HorizontalOptions="Center">
                    <Image Source="{mi:MaterialOutlined Icon=Logout}"
                           WidthRequest="16"
                           HeightRequest="16"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </FlexLayout>

        <controls:AppBottomNav Grid.Row="3"
                               ActiveItem="" />

        <controls:ProfileDrawer Grid.RowSpan="4"
                                ActiveItem="Group"
                                IsOpen="{Binding IsProfileMenuOpen}" /></Grid>
</ContentPage>
